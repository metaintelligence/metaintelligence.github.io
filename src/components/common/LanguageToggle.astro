---
import { DEFAULT_LOCALE, SUPPORTED_LOCALES } from '~/utils/i18n';

interface Props {
  compact?: boolean;
}

const { compact = false } = Astro.props;
---

<div
  class:list={[
    'inline-flex items-center border border-slate-200 bg-white p-0.5 text-xs font-semibold text-slate-600 shadow-sm dark:border-slate-800 dark:bg-slate-950 dark:text-slate-300',
    compact ? 'scale-95' : '',
  ]}
  aria-label="Language"
  data-language-switcher
>
  {
    SUPPORTED_LOCALES.map((locale) => (
      <button
        type="button"
        class="mi-lang-button min-w-9 px-2.5 py-1.5 transition hover:text-slate-950 dark:hover:text-white"
        data-lang-option={locale.code}
        aria-label={locale.label}
        aria-pressed={locale.code === DEFAULT_LOCALE ? 'true' : 'false'}
      >
        {locale.shortLabel}
      </button>
    ))
  }
</div>

<style>
  .mi-lang-button[aria-pressed='true'] {
    border-color: #020617;
    background: #020617;
    color: #ffffff;
  }

  :global(.dark) .mi-lang-button[aria-pressed='true'] {
    border-color: #ffffff;
    background: #ffffff;
    color: #020617;
  }
</style>
