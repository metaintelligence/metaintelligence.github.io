---
import { DEFAULT_LOCALE, dictionaries } from '~/utils/i18n';
---

<script is:inline define:vars={{ defaultLocale: DEFAULT_LOCALE, dictionaries, storageKey: 'mi.locale' }}>
  const languageWindow = window;

  const readStoredLocale = () => {
    try {
      return window.localStorage.getItem(storageKey);
    } catch {
      return null;
    }
  };

  const writeStoredLocale = (locale) => {
    try {
      window.localStorage.setItem(storageKey, locale);
    } catch {
      // Storage can be unavailable in strict privacy contexts.
    }
  };

  const getValue = (source, key) =>
    key.split('.').reduce((current, part) => {
      if (current && typeof current === 'object' && part in current) {
        return current[part];
      }

      return undefined;
    }, source);

  const applyLanguage = (locale) => {
    const safeLocale = locale && Object.prototype.hasOwnProperty.call(dictionaries, locale) ? locale : defaultLocale;
    const dictionary = dictionaries[safeLocale];

    document.documentElement.lang = safeLocale;
    writeStoredLocale(safeLocale);

    document.querySelectorAll('[data-i18n-key]').forEach((node) => {
      const key = node.getAttribute('data-i18n-key');
      const value = key ? getValue(dictionary, key) : undefined;

      if (typeof value === 'string') {
        node.textContent = value;
      }
    });

    document.querySelectorAll('[data-i18n-attrs]').forEach((node) => {
      const attrs = (node.getAttribute('data-i18n-attrs') || '')
        .split(',')
        .map((attr) => attr.trim())
        .filter(Boolean);

      attrs.forEach((attr) => {
        const key = node.getAttribute(`data-i18n-attr-${attr}`);
        const value = key ? getValue(dictionary, key) : undefined;

        if (typeof value === 'string') {
          node.setAttribute(attr, value);
        }
      });
    });

    document.querySelectorAll('[data-lang-option]').forEach((button) => {
      button.setAttribute('aria-pressed', String(button.getAttribute('data-lang-option') === safeLocale));
    });
  };

  languageWindow.__metaIntelligenceApplyLanguage = applyLanguage;

  if (!languageWindow.__metaIntelligenceLanguageBound) {
    languageWindow.__metaIntelligenceLanguageBound = true;

    document.addEventListener('click', (event) => {
      const target = event.target instanceof Element ? event.target.closest('[data-lang-option]') : null;

      if (target) {
        applyLanguage(target.getAttribute('data-lang-option'));
      }
    });

    document.addEventListener('astro:page-load', () => {
      applyLanguage(readStoredLocale() || defaultLocale);
    });
  }

  applyLanguage(readStoredLocale() || defaultLocale);
</script>
