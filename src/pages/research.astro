---
import { Icon } from 'astro-icon/components';

import Layout from '~/layouts/PageLayout.astro';
import { researchHighlights } from '~/data/site';

const metadata = {
  title: 'Research & IP',
  description: 'MetaIntelligence research, intellectual property, and publication highlights.',
};

const ipItems = [
  {
    title: 'Registered patent KR 10-2573563',
    description:
      'Natural data analysis system and method. The IP supports the company approach to structured analysis of R&D and technical data.',
  },
  {
    title: 'Registered trademark KR 40-1914547',
    description:
      'Trademark asset from the earlier MetaCom2 period, retained as part of the company history and public IP context.',
  },
  {
    title: 'Applied research record',
    description:
      'Research activity is presented as technical context only; confidential contracts and private partner details are excluded.',
  },
];

const publications = [
  'Future-issue analysis based on collection and analysis of global R&D funding status',
  'Pittcon poster presentation on R&D funding data and future issue discovery',
  'Big-data analysis of NSF project abstracts and data-physics methodology',
  'Public R&D analytics reports built from policy research assignments',
];
---

<Layout metadata={metadata}>
  <section class="not-prose bg-white py-16 dark:bg-slate-950 md:py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6">
      <div class="max-w-4xl">
        <p class="text-sm font-bold uppercase tracking-wide text-blue-700 dark:text-blue-300">Research & IP</p>
        <h1 class="mt-4 text-4xl font-bold tracking-tight text-slate-950 dark:text-white md:text-6xl">
          Research methods and IP behind the product direction
        </h1>
        <p class="mt-6 text-lg leading-relaxed text-slate-600 dark:text-slate-300 md:text-xl">
          MetaIntelligence connects natural data analysis, R&D data physics, emerging technology discovery, and
          manufacturing vision AI into a verification-driven technical foundation.
        </p>
      </div>
    </div>
  </section>

  <section class="not-prose bg-slate-50 py-16 dark:bg-slate-900 md:py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6">
      <div class="grid gap-5 md:grid-cols-3">
        {
          ipItems.map((item) => (
            <article class="border border-slate-200 bg-white p-7 dark:border-slate-800 dark:bg-slate-950">
              <Icon name="tabler:certificate" class="h-9 w-9 text-blue-700 dark:text-blue-300" />
              <h2 class="mt-6 text-2xl font-bold text-slate-950 dark:text-white">{item.title}</h2>
              <p class="mt-4 leading-relaxed text-slate-600 dark:text-slate-300">{item.description}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="not-prose bg-white py-16 dark:bg-slate-950 md:py-24">
    <div class="mx-auto grid max-w-7xl gap-12 px-4 sm:px-6 lg:grid-cols-[0.8fr_1.2fr]">
      <div>
        <p class="text-sm font-bold uppercase tracking-wide text-blue-700 dark:text-blue-300">Research Themes</p>
        <h2 class="mt-3 text-3xl font-bold tracking-tight text-slate-950 dark:text-white md:text-5xl">
          Public-safe research themes
        </h2>
      </div>
      <div class="grid gap-4 md:grid-cols-2">
        {
          researchHighlights.map((item) => (
            <article class="border border-slate-200 p-6 dark:border-slate-800">
              <h3 class="text-xl font-bold text-slate-950 dark:text-white">{item.title}</h3>
              <p class="mt-3 leading-relaxed text-slate-600 dark:text-slate-300">{item.description}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="not-prose bg-slate-950 py-16 text-white md:py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6">
      <div class="max-w-3xl">
        <p class="text-sm font-bold uppercase tracking-wide text-blue-200">Publications & Reports</p>
        <h2 class="mt-3 text-3xl font-bold tracking-tight md:text-5xl">
          Research activity that supports the platform direction
        </h2>
      </div>
      <div class="mt-10 grid gap-3 md:grid-cols-2">
        {
          publications.map((item) => (
            <div class="flex gap-4 border border-white/10 bg-white/[0.03] p-5">
              <Icon name="tabler:file-text" class="mt-1 h-5 w-5 shrink-0 text-blue-200" />
              <p class="leading-relaxed text-slate-300">{item}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>
</Layout>
