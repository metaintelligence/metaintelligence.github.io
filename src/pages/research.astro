---
import { Icon } from 'astro-icon/components';

import Layout from '~/layouts/PageLayout.astro';
import { createTranslator } from '~/utils/i18n';

const t = createTranslator();

const metadata = {
  title: t('pages.research.metaTitle'),
  description: t('pages.research.metaDescription'),
};

const ipKeys = ['patent', 'trademark', 'record'];
const researchHighlightKeys = ['natural', 'physics', 'signal', 'public'];
const publicationKeys = ['future', 'pittcon', 'nsf', 'reports'];
---

<Layout metadata={metadata}>
  <section class="not-prose bg-white py-16 dark:bg-slate-950 md:py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6">
      <div class="max-w-4xl">
        <p
          class="text-sm font-bold uppercase tracking-wide text-blue-700 dark:text-blue-300"
          data-i18n-key="pages.research.eyebrow"
        >
          {t('pages.research.eyebrow')}
        </p>
        <h1
          class="mt-4 text-4xl font-bold tracking-tight text-slate-950 dark:text-white md:text-6xl"
          data-i18n-key="pages.research.title"
        >
          {t('pages.research.title')}
        </h1>
        <p
          class="mt-6 text-lg leading-relaxed text-slate-600 dark:text-slate-300 md:text-xl"
          data-i18n-key="pages.research.description"
        >
          {t('pages.research.description')}
        </p>
      </div>
    </div>
  </section>

  <section class="not-prose bg-slate-50 py-16 dark:bg-slate-900 md:py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6">
      <div class="grid gap-5 md:grid-cols-3">
        {
          ipKeys.map((key) => (
            <article class="border border-slate-200 bg-white p-7 dark:border-slate-800 dark:bg-slate-950">
              <Icon name="tabler:certificate" class="h-9 w-9 text-blue-700 dark:text-blue-300" />
              <h2
                class="mt-6 text-2xl font-bold text-slate-950 dark:text-white"
                data-i18n-key={`pages.research.ip.${key}.title`}
              >
                {t(`pages.research.ip.${key}.title`)}
              </h2>
              <p
                class="mt-4 leading-relaxed text-slate-600 dark:text-slate-300"
                data-i18n-key={`pages.research.ip.${key}.description`}
              >
                {t(`pages.research.ip.${key}.description`)}
              </p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="not-prose bg-white py-16 dark:bg-slate-950 md:py-24">
    <div class="mx-auto grid max-w-7xl gap-12 px-4 sm:px-6 lg:grid-cols-[0.8fr_1.2fr]">
      <div>
        <p
          class="text-sm font-bold uppercase tracking-wide text-blue-700 dark:text-blue-300"
          data-i18n-key="pages.research.themesEyebrow"
        >
          {t('pages.research.themesEyebrow')}
        </p>
        <h2
          class="mt-3 text-3xl font-bold tracking-tight text-slate-950 dark:text-white md:text-5xl"
          data-i18n-key="pages.research.themesTitle"
        >
          {t('pages.research.themesTitle')}
        </h2>
      </div>
      <div class="grid gap-4 md:grid-cols-2">
        {
          researchHighlightKeys.map((key) => (
            <article class="border border-slate-200 p-6 dark:border-slate-800">
              <h3
                class="text-xl font-bold text-slate-950 dark:text-white"
                data-i18n-key={`data.researchHighlights.${key}.title`}
              >
                {t(`data.researchHighlights.${key}.title`)}
              </h3>
              <p
                class="mt-3 leading-relaxed text-slate-600 dark:text-slate-300"
                data-i18n-key={`data.researchHighlights.${key}.description`}
              >
                {t(`data.researchHighlights.${key}.description`)}
              </p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="not-prose bg-slate-950 py-16 text-white md:py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6">
      <div class="max-w-3xl">
        <p
          class="text-sm font-bold uppercase tracking-wide text-blue-200"
          data-i18n-key="pages.research.publicationsEyebrow"
        >
          {t('pages.research.publicationsEyebrow')}
        </p>
        <h2 class="mt-3 text-3xl font-bold tracking-tight md:text-5xl" data-i18n-key="pages.research.publicationsTitle">
          {t('pages.research.publicationsTitle')}
        </h2>
      </div>
      <div class="mt-10 grid gap-3 md:grid-cols-2">
        {
          publicationKeys.map((key) => (
            <div class="flex gap-4 border border-white/10 bg-white/[0.03] p-5">
              <Icon name="tabler:file-text" class="mt-1 h-5 w-5 shrink-0 text-blue-200" />
              <p class="leading-relaxed text-slate-300" data-i18n-key={`pages.research.publications.${key}`}>
                {t(`pages.research.publications.${key}`)}
              </p>
            </div>
          ))
        }
      </div>
    </div>
  </section>
</Layout>
