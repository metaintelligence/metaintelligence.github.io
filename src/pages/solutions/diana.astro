---
import { Icon } from 'astro-icon/components';

import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'DIANA - Domain Intelligence Agent',
  description:
    'DIANA is the agentic intelligence layer on MetaInsight for source-grounded domain analysis and knowledge workflows.',
};

const agents = [
  ['Ingestion', 'Collect and structure domain records, documents, logs, reports, patents, and technical materials.'],
  ['Analysis', 'Compute domain signals from clusters, trends, quantitative indicators, and operating rules.'],
  ['Structuring', 'Organize definitions, evidence, applications, risks, and decisions into repeatable templates.'],
  ['Cross-Check', 'Compare generated statements with source databases and retrieved evidence.'],
  ['Pre-Detection', 'Surface candidate signals before they become obvious through manual review.'],
  ['Guard', 'Reduce unsupported generation, numerical errors, and overconfident conclusions through evaluation gates.'],
];

const outputs = [
  'Domain intelligence briefs',
  'Quantitative trend, risk, or opportunity review',
  'Cross-map across records, documents, reports, and source evidence',
  'Draft reports with verification logs',
];

const intelligenceLayers = [
  {
    step: '01',
    title: 'Evidence Layer',
    body: 'Domain datasets, documents, logs, reports, and technical materials are normalized with source identifiers.',
    output: 'Structured evidence base',
  },
  {
    step: '02',
    title: 'Agent Layer',
    body: 'Planning, retrieval, quantitative checks, and drafting are separated into reviewable agent tasks.',
    output: 'Traceable analysis path',
  },
  {
    step: '03',
    title: 'Output Layer',
    body: 'Briefs, review notes, and report drafts are produced with linked evidence and verification context.',
    output: 'Reusable intelligence unit',
  },
];

const verificationSteps = [
  ['Input Gate', 'Accept only structured records, source URIs, and analyst-approved context.'],
  ['Calculation Gate', 'Run quantitative scoring and rule checks outside free-form generation.'],
  ['Retrieval Gate', 'Attach supporting records before a claim enters the draft.'],
  ['Cross-Check Gate', 'Compare conclusions against retrieved evidence and known domain rules.'],
  ['Review Gate', 'Expose assumptions, weak signals, and missing evidence for analyst correction.'],
  ['Fallback Gate', 'Defer or mark uncertainty when the evidence path is incomplete.'],
];
---

<Layout metadata={metadata}>
  <section class="not-prose bg-white py-16 dark:bg-slate-950 md:py-24">
    <div class="mx-auto grid max-w-7xl gap-12 px-4 sm:px-6 lg:grid-cols-[0.88fr_1.12fr] lg:items-center">
      <div class="max-w-4xl">
        <p class="text-sm font-bold uppercase tracking-wide text-violet-700 dark:text-violet-300">DIANA</p>
        <h1 class="mt-4 text-4xl font-bold tracking-tight text-slate-950 dark:text-white md:text-6xl">
          Agentic intelligence for repeatable domain analysis
        </h1>
        <p class="mt-6 text-lg leading-relaxed text-slate-600 dark:text-slate-300 md:text-xl">
          DIANA is the agent layer that extends MetaInsight from analytics into guided knowledge work. It is designed to
          retrieve evidence, plan domain-specific analysis steps, draft outputs, and preserve verification context.
        </p>
      </div>
      <div class="border border-slate-200 bg-slate-50 p-5 dark:border-slate-800 dark:bg-slate-900">
        <p class="text-xs font-bold uppercase tracking-[0.18em] text-violet-700 dark:text-violet-300">
          Technical Architecture
        </p>
        <div class="mt-5 grid gap-4">
          {
            intelligenceLayers.map((layer) => (
              <article class="border border-slate-200 bg-white p-5 dark:border-slate-800 dark:bg-slate-950">
                <div class="flex flex-col gap-4 sm:flex-row sm:items-start">
                  <span class="inline-flex h-10 w-10 shrink-0 items-center justify-center bg-violet-700 text-sm font-bold text-white dark:bg-violet-300 dark:text-slate-950">
                    {layer.step}
                  </span>
                  <div>
                    <h2 class="text-xl font-bold text-slate-950 dark:text-white">{layer.title}</h2>
                    <p class="mt-2 text-sm leading-relaxed text-slate-600 dark:text-slate-300">{layer.body}</p>
                    <p class="mt-3 border-l-2 border-violet-500 pl-3 text-sm font-semibold text-slate-950 dark:text-white">
                      {layer.output}
                    </p>
                  </div>
                </div>
              </article>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <section class="not-prose bg-slate-50 py-16 dark:bg-slate-900 md:py-24">
    <div class="mx-auto grid max-w-7xl gap-5 px-4 sm:px-6 md:grid-cols-2 lg:grid-cols-3">
      {
        agents.map(([title, description]) => (
          <article class="border border-slate-200 bg-white p-7 dark:border-slate-800 dark:bg-slate-950">
            <Icon name="tabler:hexagon-letter-d" class="h-9 w-9 text-violet-700 dark:text-violet-300" />
            <h2 class="mt-6 text-xl font-bold text-slate-950 dark:text-white">{title}</h2>
            <p class="mt-3 text-sm leading-relaxed text-slate-600 dark:text-slate-300">{description}</p>
          </article>
        ))
      }
    </div>
  </section>

  <section class="not-prose bg-white py-16 dark:bg-slate-950 md:py-24">
    <div class="mx-auto grid max-w-7xl gap-12 px-4 sm:px-6 lg:grid-cols-[0.8fr_1.2fr]">
      <div>
        <p class="text-sm font-bold uppercase tracking-wide text-violet-700 dark:text-violet-300">Output</p>
        <h2 class="mt-3 text-3xl font-bold tracking-tight text-slate-950 dark:text-white md:text-5xl">
          Outputs analysts can inspect and improve
        </h2>
        <p class="mt-5 leading-relaxed text-slate-600 dark:text-slate-300">
          DIANA is not positioned as a free-form chatbot. Its value is in structuring evidence-backed intelligence units
          that can be reviewed, revised, and reused.
        </p>
      </div>
      <div class="grid gap-4 md:grid-cols-2">
        {
          outputs.map((item) => (
            <div class="flex gap-4 border border-slate-200 p-5 dark:border-slate-800">
              <Icon name="tabler:check" class="mt-1 h-5 w-5 shrink-0 text-violet-700 dark:text-violet-300" />
              <p class="leading-relaxed text-slate-600 dark:text-slate-300">{item}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section class="not-prose bg-slate-50 py-16 dark:bg-slate-900 md:py-24">
    <div class="mx-auto grid max-w-7xl gap-12 px-4 sm:px-6 lg:grid-cols-[0.82fr_1.18fr] lg:items-center">
      <div>
        <p class="text-sm font-bold uppercase tracking-wide text-violet-700 dark:text-violet-300">Verification</p>
        <h2 class="mt-3 text-3xl font-bold tracking-tight text-slate-950 dark:text-white md:text-5xl">
          Generation is separated from evidence and calculation
        </h2>
        <p class="mt-5 leading-relaxed text-slate-600 dark:text-slate-300">
          DIANA is positioned around structured evidence, program-aided calculation, cross-checking, source tracking,
          and fallback behavior when confidence is insufficient.
        </p>
      </div>
      <div class="grid gap-3 sm:grid-cols-2">
        {
          verificationSteps.map(([title, description], index) => (
            <article class="border border-slate-200 bg-white p-5 dark:border-slate-800 dark:bg-slate-950">
              <p class="text-xs font-bold uppercase tracking-wide text-violet-700 dark:text-violet-300">
                Gate {String(index + 1).padStart(2, '0')}
              </p>
              <h3 class="mt-3 text-lg font-bold text-slate-950 dark:text-white">{title}</h3>
              <p class="mt-2 text-sm leading-relaxed text-slate-600 dark:text-slate-300">{description}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="not-prose bg-slate-950 py-16 text-white md:py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6">
      <div class="grid gap-8 lg:grid-cols-[0.75fr_1.25fr]">
        <div>
          <p class="text-sm font-bold uppercase tracking-wide text-violet-200">Positioning</p>
          <h2 class="mt-3 text-3xl font-bold tracking-tight md:text-5xl">The agent path after MetaInsight</h2>
        </div>
        <p class="text-lg leading-relaxed text-slate-300">
          DIANA is planned as an extension of the same verified data foundation used by MetaInsight. The roadmap is
          aimed at domain signal analysis, policy research, risk review, technical intelligence, and enterprise
          document-analysis workflows.
        </p>
      </div>
    </div>
  </section>
</Layout>
