---
import { Icon } from 'astro-icon/components';

import Layout from '~/layouts/PageLayout.astro';
import { createTranslator } from '~/utils/i18n';

const t = createTranslator();

const metadata = {
  title: t('pages.diana.metaTitle'),
  description: t('pages.diana.metaDescription'),
};

const agents = ['ingestion', 'analysis', 'structuring', 'crossCheck', 'preDetection', 'guard'];

const outputs = ['briefs', 'trend', 'crossMap', 'drafts'];

const intelligenceLayers = [
  {
    step: '01',
    key: 'evidence',
  },
  {
    step: '02',
    key: 'agent',
  },
  {
    step: '03',
    key: 'output',
  },
];

const verificationSteps = ['input', 'calculation', 'retrieval', 'crossCheck', 'review', 'fallback'];
---

<Layout metadata={metadata}>
  <section class="not-prose bg-white py-16 dark:bg-slate-950 md:py-24">
    <div class="mx-auto grid max-w-7xl gap-12 px-4 sm:px-6 lg:grid-cols-[0.88fr_1.12fr] lg:items-center">
      <div class="max-w-4xl">
        <p
          class="text-sm font-bold uppercase tracking-wide text-violet-700 dark:text-violet-300"
          data-i18n-key="pages.diana.eyebrow"
        >
          {t('pages.diana.eyebrow')}
        </p>
        <h1
          class="mt-4 text-4xl font-bold tracking-tight text-slate-950 dark:text-white md:text-6xl"
          data-i18n-key="pages.diana.title"
        >
          {t('pages.diana.title')}
        </h1>
        <p
          class="mt-6 text-lg leading-relaxed text-slate-600 dark:text-slate-300 md:text-xl"
          data-i18n-key="pages.diana.description"
        >
          {t('pages.diana.description')}
        </p>
      </div>
      <div class="border border-slate-200 bg-slate-50 p-5 dark:border-slate-800 dark:bg-slate-900">
        <p class="text-xs font-bold uppercase tracking-[0.18em] text-violet-700 dark:text-violet-300">
          <span data-i18n-key="pages.diana.architectureLabel">{t('pages.diana.architectureLabel')}</span>
        </p>
        <div class="mt-5 grid gap-4">
          {
            intelligenceLayers.map((layer) => (
              <article class="border border-slate-200 bg-white p-5 dark:border-slate-800 dark:bg-slate-950">
                <div class="flex flex-col gap-4 sm:flex-row sm:items-start">
                  <span class="inline-flex h-10 w-10 shrink-0 items-center justify-center bg-violet-700 text-sm font-bold text-white dark:bg-violet-300 dark:text-slate-950">
                    {layer.step}
                  </span>
                  <div>
                    <h2
                      class="text-xl font-bold text-slate-950 dark:text-white"
                      data-i18n-key={`pages.diana.layers.${layer.key}.title`}
                    >
                      {t(`pages.diana.layers.${layer.key}.title`)}
                    </h2>
                    <p
                      class="mt-2 text-sm leading-relaxed text-slate-600 dark:text-slate-300"
                      data-i18n-key={`pages.diana.layers.${layer.key}.body`}
                    >
                      {t(`pages.diana.layers.${layer.key}.body`)}
                    </p>
                    <p
                      class="mt-3 border-l-2 border-violet-500 pl-3 text-sm font-semibold text-slate-950 dark:text-white"
                      data-i18n-key={`pages.diana.layers.${layer.key}.output`}
                    >
                      {t(`pages.diana.layers.${layer.key}.output`)}
                    </p>
                  </div>
                </div>
              </article>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <section class="not-prose bg-slate-50 py-16 dark:bg-slate-900 md:py-24">
    <div class="mx-auto grid max-w-7xl gap-5 px-4 sm:px-6 md:grid-cols-2 lg:grid-cols-3">
      {
        agents.map((key) => (
          <article class="border border-slate-200 bg-white p-7 dark:border-slate-800 dark:bg-slate-950">
            <Icon name="tabler:hexagon-letter-d" class="h-9 w-9 text-violet-700 dark:text-violet-300" />
            <h2
              class="mt-6 text-xl font-bold text-slate-950 dark:text-white"
              data-i18n-key={`pages.diana.agentTitles.${key}`}
            >
              {t(`pages.diana.agentTitles.${key}`)}
            </h2>
            <p
              class="mt-3 text-sm leading-relaxed text-slate-600 dark:text-slate-300"
              data-i18n-key={`pages.diana.agents.${key}`}
            >
              {t(`pages.diana.agents.${key}`)}
            </p>
          </article>
        ))
      }
    </div>
  </section>

  <section class="not-prose bg-white py-16 dark:bg-slate-950 md:py-24">
    <div class="mx-auto grid max-w-7xl gap-12 px-4 sm:px-6 lg:grid-cols-[0.8fr_1.2fr]">
      <div>
        <p
          class="text-sm font-bold uppercase tracking-wide text-violet-700 dark:text-violet-300"
          data-i18n-key="pages.diana.outputEyebrow"
        >
          {t('pages.diana.outputEyebrow')}
        </p>
        <h2
          class="mt-3 text-3xl font-bold tracking-tight text-slate-950 dark:text-white md:text-5xl"
          data-i18n-key="pages.diana.outputTitle"
        >
          {t('pages.diana.outputTitle')}
        </h2>
        <p
          class="mt-5 leading-relaxed text-slate-600 dark:text-slate-300"
          data-i18n-key="pages.diana.outputDescription"
        >
          {t('pages.diana.outputDescription')}
        </p>
      </div>
      <div class="grid gap-4 md:grid-cols-2">
        {
          outputs.map((key) => (
            <div class="flex gap-4 border border-slate-200 p-5 dark:border-slate-800">
              <Icon name="tabler:check" class="mt-1 h-5 w-5 shrink-0 text-violet-700 dark:text-violet-300" />
              <p
                class="leading-relaxed text-slate-600 dark:text-slate-300"
                data-i18n-key={`pages.diana.outputs.${key}`}
              >
                {t(`pages.diana.outputs.${key}`)}
              </p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section class="not-prose bg-slate-50 py-16 dark:bg-slate-900 md:py-24">
    <div class="mx-auto grid max-w-7xl gap-12 px-4 sm:px-6 lg:grid-cols-[0.82fr_1.18fr] lg:items-center">
      <div>
        <p
          class="text-sm font-bold uppercase tracking-wide text-violet-700 dark:text-violet-300"
          data-i18n-key="pages.diana.verificationEyebrow"
        >
          {t('pages.diana.verificationEyebrow')}
        </p>
        <h2
          class="mt-3 text-3xl font-bold tracking-tight text-slate-950 dark:text-white md:text-5xl"
          data-i18n-key="pages.diana.verificationTitle"
        >
          {t('pages.diana.verificationTitle')}
        </h2>
        <p
          class="mt-5 leading-relaxed text-slate-600 dark:text-slate-300"
          data-i18n-key="pages.diana.verificationDescription"
        >
          {t('pages.diana.verificationDescription')}
        </p>
      </div>
      <div class="grid gap-3 sm:grid-cols-2">
        {
          verificationSteps.map((key, index) => (
            <article class="border border-slate-200 bg-white p-5 dark:border-slate-800 dark:bg-slate-950">
              <p class="text-xs font-bold uppercase tracking-wide text-violet-700 dark:text-violet-300">
                <span data-i18n-key="pages.diana.gate">{t('pages.diana.gate')}</span>{' '}
                {String(index + 1).padStart(2, '0')}
              </p>
              <h3
                class="mt-3 text-lg font-bold text-slate-950 dark:text-white"
                data-i18n-key={`pages.diana.verificationSteps.${key}.title`}
              >
                {t(`pages.diana.verificationSteps.${key}.title`)}
              </h3>
              <p
                class="mt-2 text-sm leading-relaxed text-slate-600 dark:text-slate-300"
                data-i18n-key={`pages.diana.verificationSteps.${key}.description`}
              >
                {t(`pages.diana.verificationSteps.${key}.description`)}
              </p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="not-prose bg-slate-950 py-16 text-white md:py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6">
      <div class="grid gap-8 lg:grid-cols-[0.75fr_1.25fr]">
        <div>
          <p
            class="text-sm font-bold uppercase tracking-wide text-violet-200"
            data-i18n-key="pages.diana.positioningEyebrow"
          >
            {t('pages.diana.positioningEyebrow')}
          </p>
          <h2 class="mt-3 text-3xl font-bold tracking-tight md:text-5xl" data-i18n-key="pages.diana.positioningTitle">
            {t('pages.diana.positioningTitle')}
          </h2>
        </div>
        <p class="text-lg leading-relaxed text-slate-300" data-i18n-key="pages.diana.positioningDescription">
          {t('pages.diana.positioningDescription')}
        </p>
      </div>
    </div>
  </section>
</Layout>
