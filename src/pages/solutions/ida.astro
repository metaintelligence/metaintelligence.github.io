---
import Layout from '~/layouts/PageLayout.astro';
import { createTranslator } from '~/utils/i18n';
import { getPermalink } from '~/utils/permalinks';

const t = createTranslator();

const metadata = {
  title: t('pages.ida.metaTitle'),
  description: t('pages.ida.metaDescription'),
  robots: { index: false, follow: true },
};
---

<Layout metadata={metadata}>
  <section class="not-prose bg-white py-16 dark:bg-slate-950 md:py-24">
    <div class="mx-auto max-w-3xl px-4 sm:px-6">
      <p
        class="text-sm font-bold uppercase tracking-wide text-blue-700 dark:text-blue-300"
        data-i18n-key="pages.ida.eyebrow"
      >
        {t('pages.ida.eyebrow')}
      </p>
      <h1 class="mt-4 text-4xl font-bold tracking-tight text-slate-950 dark:text-white" data-i18n-key="pages.ida.title">
        {t('pages.ida.title')}
      </h1>
      <p class="mt-6 leading-relaxed text-slate-600 dark:text-slate-300" data-i18n-key="pages.ida.description">
        {t('pages.ida.description')}
      </p>
      <a
        href={getPermalink('/solutions/metainsight')}
        class="mt-8 inline-flex bg-blue-700 px-5 py-3 text-sm font-semibold text-white hover:bg-blue-800"
      >
        <span data-i18n-key="pages.ida.cta">{t('pages.ida.cta')}</span>
      </a>
    </div>
  </section>
</Layout>
