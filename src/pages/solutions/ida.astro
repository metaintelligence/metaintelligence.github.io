---
import Layout from '~/layouts/PageLayout.astro';
import { getPermalink } from '~/utils/permalinks';

const metadata = {
  title: 'MetaInsight',
  description: 'IDA has been consolidated into MetaInsight, the R&D intelligence platform.',
  robots: { index: false, follow: true },
};
---

<Layout metadata={metadata}>
  <section class="not-prose bg-white py-16 dark:bg-slate-950 md:py-24">
    <div class="mx-auto max-w-3xl px-4 sm:px-6">
      <p class="text-sm font-bold uppercase tracking-wide text-blue-700 dark:text-blue-300">Renamed</p>
      <h1 class="mt-4 text-4xl font-bold tracking-tight text-slate-950 dark:text-white">
        IDA is now presented as MetaInsight
      </h1>
      <p class="mt-6 leading-relaxed text-slate-600 dark:text-slate-300">
        The former document and research-data analytics experience has been consolidated into MetaInsight, the public
        R&D intelligence platform page.
      </p>
      <a
        href={getPermalink('/solutions/metainsight')}
        class="mt-8 inline-flex bg-blue-700 px-5 py-3 text-sm font-semibold text-white hover:bg-blue-800"
      >
        View MetaInsight
      </a>
    </div>
  </section>
</Layout>
