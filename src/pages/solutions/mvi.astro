---
import { Icon } from 'astro-icon/components';

import Layout from '~/layouts/PageLayout.astro';
import { createTranslator } from '~/utils/i18n';

import inspectThumbnail from '~/assets/images/mvi/mvi_inspect_thumbnail.png';
import augmentGoodThumbnail from '~/assets/images/mvi/mvi_augment_gd_thumbnail.png';
import augmentDefectThumbnail from '~/assets/images/mvi/mvi_augment_defect_thumbnail.png';
import mviEvidence from '~/assets/images/refs/mvi-defect-evidence.png';
import inspectVideo from '~/assets/video/3_inspect.mp4';
import augmentGoodVideo from '~/assets/video/4_augment_ng_to_gd.mp4';
import augmentDefectVideo from '~/assets/video/5_augment_gd_to_burr.mp4';

const t = createTranslator();

const metadata = {
  title: t('pages.mvi.metaTitle'),
  description: t('pages.mvi.metaDescription'),
};

const valueProps = [
  {
    key: 'ready',
    icon: 'tabler:player-play',
  },
  {
    key: 'expert',
    icon: 'tabler:user-check',
  },
  {
    key: 'adaptive',
    icon: 'tabler:adjustments',
  },
];

const pipeline = [
  ['01', 'gate'],
  ['02', 'detect'],
  ['03', 'augment'],
  ['04', 'operation'],
];

const demos = [
  {
    key: 'inspect',
    video: inspectVideo,
    poster: inspectThumbnail,
    icon: 'tabler:scan-eye',
  },
  {
    key: 'good',
    video: augmentGoodVideo,
    poster: augmentGoodThumbnail,
    icon: 'tabler:sparkles',
  },
  {
    key: 'defect',
    video: augmentDefectVideo,
    poster: augmentDefectThumbnail,
    icon: 'tabler:wand',
  },
];

const initialDemo = demos[0];
---

<Layout metadata={metadata}>
  <section class="not-prose bg-white py-16 dark:bg-slate-950 md:py-24">
    <div class="mx-auto grid max-w-7xl gap-12 px-4 sm:px-6 lg:grid-cols-[0.9fr_1.1fr] lg:items-center">
      <div>
        <p class="text-sm font-bold uppercase tracking-wide text-emerald-700 dark:text-emerald-300">
          <span data-i18n-key="pages.mvi.eyebrow">{t('pages.mvi.eyebrow')}</span>
        </p>
        <h1
          class="mt-4 text-4xl font-bold tracking-tight text-slate-950 dark:text-white md:text-6xl"
          data-i18n-key="pages.mvi.title"
        >
          {t('pages.mvi.title')}
        </h1>
        <p
          class="mt-6 text-lg leading-relaxed text-slate-600 dark:text-slate-300 md:text-xl"
          data-i18n-key="pages.mvi.description"
        >
          {t('pages.mvi.description')}
        </p>
        <div class="mt-8 grid gap-3 sm:grid-cols-3">
          {
            ['One-Class', 'GenAI', '3-BIN'].map((item) => (
              <div class="border border-slate-200 p-4 dark:border-slate-800">
                <strong class="block text-slate-950 dark:text-white">{item}</strong>
                <span
                  class="mt-1 block text-sm text-slate-500 dark:text-slate-400"
                  data-i18n-key="pages.mvi.badgeSubtitle"
                >
                  {t('pages.mvi.badgeSubtitle')}
                </span>
              </div>
            ))
          }
        </div>
      </div>
      <div
        class="overflow-hidden border border-slate-200 bg-slate-950 shadow-2xl shadow-slate-200 dark:border-slate-800 dark:shadow-none"
      >
        <video
          class="aspect-video w-full object-cover"
          src={inspectVideo}
          poster={inspectThumbnail.src}
          autoplay
          loop
          muted
          playsinline
          controls
          preload="metadata"
          aria-label={t('pages.mvi.heroVideoLabel')}
          data-i18n-attrs="aria-label"
          data-i18n-attr-aria-label="pages.mvi.heroVideoLabel"></video>
      </div>
    </div>
  </section>

  <section class="not-prose bg-slate-50 py-16 dark:bg-slate-900 md:py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6">
      <div class="grid gap-5 md:grid-cols-3">
        {
          valueProps.map((item) => (
            <article class="border border-slate-200 bg-white p-7 dark:border-slate-800 dark:bg-slate-950">
              <Icon name={item.icon} class="h-9 w-9 text-emerald-700 dark:text-emerald-300" />
              <h2
                class="mt-6 text-2xl font-bold text-slate-950 dark:text-white"
                data-i18n-key={`pages.mvi.valueProps.${item.key}.title`}
              >
                {t(`pages.mvi.valueProps.${item.key}.title`)}
              </h2>
              <p
                class="mt-4 leading-relaxed text-slate-600 dark:text-slate-300"
                data-i18n-key={`pages.mvi.valueProps.${item.key}.description`}
              >
                {t(`pages.mvi.valueProps.${item.key}.description`)}
              </p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="not-prose bg-white py-16 dark:bg-slate-950 md:py-24">
    <div class="mx-auto grid max-w-7xl gap-12 px-4 sm:px-6 lg:grid-cols-[0.8fr_1.2fr] lg:items-center">
      <div>
        <p
          class="text-sm font-bold uppercase tracking-wide text-emerald-700 dark:text-emerald-300"
          data-i18n-key="pages.mvi.evidenceEyebrow"
        >
          {t('pages.mvi.evidenceEyebrow')}
        </p>
        <h2
          class="mt-3 text-3xl font-bold tracking-tight text-slate-950 dark:text-white md:text-5xl"
          data-i18n-key="pages.mvi.evidenceTitle"
        >
          {t('pages.mvi.evidenceTitle')}
        </h2>
        <p
          class="mt-5 text-lg leading-relaxed text-slate-600 dark:text-slate-300"
          data-i18n-key="pages.mvi.evidenceDescription"
        >
          {t('pages.mvi.evidenceDescription')}
        </p>
      </div>
      <figure class="border border-slate-200 bg-slate-50 p-4 dark:border-slate-800 dark:bg-slate-900">
        <img
          src={mviEvidence.src}
          width={mviEvidence.width}
          height={mviEvidence.height}
          alt={t('pages.mvi.evidenceAlt')}
          data-i18n-attrs="alt"
          data-i18n-attr-alt="pages.mvi.evidenceAlt"
          class="w-full object-cover"
          loading="lazy"
        />
      </figure>
    </div>
  </section>

  <section class="not-prose bg-slate-50 py-16 dark:bg-slate-900 md:py-24">
    <div class="mx-auto grid max-w-7xl gap-12 px-4 sm:px-6 lg:grid-cols-[0.75fr_1.25fr]">
      <div>
        <p class="text-sm font-bold uppercase tracking-wide text-emerald-700 dark:text-emerald-300">
          <span data-i18n-key="pages.mvi.pipelineEyebrow">{t('pages.mvi.pipelineEyebrow')}</span>
        </p>
        <h2
          class="mt-3 text-3xl font-bold tracking-tight text-slate-950 dark:text-white md:text-5xl"
          data-i18n-key="pages.mvi.pipelineTitle"
        >
          {t('pages.mvi.pipelineTitle')}
        </h2>
      </div>
      <div class="space-y-4">
        {
          pipeline.map(([label, key]) => (
            <article class="grid gap-4 border border-slate-200 bg-white p-5 dark:border-slate-800 dark:bg-slate-950 sm:grid-cols-[80px_1fr]">
              <div class="font-bold text-emerald-700 dark:text-emerald-300">{label}</div>
              <div>
                <h3 class="font-bold text-slate-950 dark:text-white" data-i18n-key={`pages.mvi.pipeline.${key}.title`}>
                  {t(`pages.mvi.pipeline.${key}.title`)}
                </h3>
                <p
                  class="mt-2 text-sm leading-relaxed text-slate-600 dark:text-slate-300"
                  data-i18n-key={`pages.mvi.pipeline.${key}.description`}
                >
                  {t(`pages.mvi.pipeline.${key}.description`)}
                </p>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="not-prose bg-slate-950 py-16 text-white md:py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6">
      <div class="max-w-3xl">
        <p class="text-sm font-bold uppercase tracking-wide text-emerald-200" data-i18n-key="pages.mvi.demosEyebrow">
          {t('pages.mvi.demosEyebrow')}
        </p>
        <h2 class="mt-3 text-3xl font-bold tracking-tight md:text-5xl" data-i18n-key="pages.mvi.demosTitle">
          {t('pages.mvi.demosTitle')}
        </h2>
        <p class="mt-5 leading-relaxed text-slate-300" data-i18n-key="pages.mvi.demosDescription">
          {t('pages.mvi.demosDescription')}
        </p>
      </div>

      <div class="mt-10 grid gap-6 lg:grid-cols-[340px_1fr]" data-mvi-demo>
        <div class="space-y-3">
          {
            demos.map((demo, index) => (
              <button
                type="button"
                class="group w-full border border-white/10 bg-white/[0.04] p-4 text-left transition hover:border-emerald-300 hover:bg-white/[0.08] aria-pressed:border-emerald-300 aria-pressed:bg-white/[0.1]"
                aria-pressed={index === 0 ? 'true' : 'false'}
                data-mvi-demo-button
                data-video={demo.video}
                data-poster={demo.poster.src}
                data-title={t(`pages.mvi.demos.${demo.key}.title`)}
                data-description={t(`pages.mvi.demos.${demo.key}.description`)}
                data-video-label={t(`pages.mvi.demos.${demo.key}.videoLabel`)}
                data-title-key={`pages.mvi.demos.${demo.key}.title`}
                data-description-key={`pages.mvi.demos.${demo.key}.description`}
                data-video-label-key={`pages.mvi.demos.${demo.key}.videoLabel`}
                data-i18n-attrs="data-title,data-description,data-video-label"
                data-i18n-attr-data-title={`pages.mvi.demos.${demo.key}.title`}
                data-i18n-attr-data-description={`pages.mvi.demos.${demo.key}.description`}
                data-i18n-attr-data-video-label={`pages.mvi.demos.${demo.key}.videoLabel`}
              >
                <span class="grid grid-cols-[96px_1fr] gap-4">
                  <span class="relative block bg-black">
                    <img
                      src={demo.poster.src}
                      width={demo.poster.width}
                      height={demo.poster.height}
                      alt={t(`pages.mvi.demos.${demo.key}.thumbnailAlt`)}
                      data-i18n-attrs="alt"
                      data-i18n-attr-alt={`pages.mvi.demos.${demo.key}.thumbnailAlt`}
                      class="aspect-video h-full w-full object-cover"
                      loading="lazy"
                    />
                    <span class="absolute inset-0 flex items-center justify-center bg-black/20">
                      <Icon name={demo.icon} class="h-6 w-6 text-emerald-200" />
                    </span>
                  </span>
                  <span class="min-w-0">
                    <span class="block font-bold text-white" data-i18n-key={`pages.mvi.demos.${demo.key}.title`}>
                      {t(`pages.mvi.demos.${demo.key}.title`)}
                    </span>
                    <span
                      class="mt-2 block text-sm leading-relaxed text-slate-300"
                      data-i18n-key={`pages.mvi.demos.${demo.key}.description`}
                    >
                      {t(`pages.mvi.demos.${demo.key}.description`)}
                    </span>
                  </span>
                </span>
              </button>
            ))
          }
        </div>

        <article class="overflow-hidden border border-white/10 bg-white/[0.04]">
          <video
            class="aspect-video w-full bg-black object-contain"
            src={initialDemo.video}
            poster={initialDemo.poster.src}
            muted
            playsinline
            controls
            preload="metadata"
            data-mvi-video
            aria-label={t(`pages.mvi.demos.${initialDemo.key}.videoLabel`)}
            data-i18n-attrs="aria-label"
            data-i18n-attr-aria-label={`pages.mvi.demos.${initialDemo.key}.videoLabel`}></video>
          <div class="border-t border-white/10 p-5 md:p-6">
            <div class="flex flex-col gap-5 md:flex-row md:items-start">
              <button
                type="button"
                class="inline-flex shrink-0 items-center justify-center gap-2 bg-emerald-300 px-4 py-3 text-sm font-bold text-slate-950 transition hover:bg-emerald-200"
                data-mvi-play
              >
                <Icon name="tabler:player-play-filled" class="h-5 w-5" />
                <span data-i18n-key="pages.mvi.play">{t('pages.mvi.play')}</span>
              </button>
              <div>
                <h3 class="text-xl font-bold" data-mvi-title data-i18n-key={`pages.mvi.demos.${initialDemo.key}.title`}>
                  {t(`pages.mvi.demos.${initialDemo.key}.title`)}
                </h3>
                <p
                  class="mt-2 leading-relaxed text-slate-300"
                  data-mvi-description
                  data-i18n-key={`pages.mvi.demos.${initialDemo.key}.description`}
                >
                  {t(`pages.mvi.demos.${initialDemo.key}.description`)}
                </p>
              </div>
            </div>
          </div>
        </article>
      </div>
    </div>
  </section>

  <script>
    const playVideo = (video: Element | null) => {
      if (!(video instanceof HTMLVideoElement)) return;
      video.muted = true;
      const playPromise = video.play();
      if (playPromise && typeof playPromise.catch === 'function') {
        playPromise.catch(() => {});
      }
    };

    const initMviDemo = () => {
      document.querySelectorAll('[data-mvi-demo]').forEach((root) => {
        if (root.getAttribute('data-bound') === 'true') return;
        root.setAttribute('data-bound', 'true');

        const video = root.querySelector('[data-mvi-video]');
        const playButton = root.querySelector('[data-mvi-play]');
        const title = root.querySelector('[data-mvi-title]');
        const description = root.querySelector('[data-mvi-description]');
        const buttons = Array.from(root.querySelectorAll('[data-mvi-demo-button]'));

        const selectDemo = (button: Element) => {
          if (!(button instanceof HTMLElement) || !(video instanceof HTMLVideoElement)) return;

          buttons.forEach((item) => item.setAttribute('aria-pressed', item === button ? 'true' : 'false'));

          const nextVideo = button.dataset.video;
          const nextPoster = button.dataset.poster;
          const nextTitle = button.dataset.title || '';
          const nextDescription = button.dataset.description || '';
          const nextVideoLabel = button.dataset.videoLabel || `MVI ${nextTitle} demo`;

          if (nextVideo && video.getAttribute('src') !== nextVideo) {
            video.pause();
            video.setAttribute('src', nextVideo);
            if (nextPoster) video.setAttribute('poster', nextPoster);
            video.load();
          }

          video.setAttribute('aria-label', nextVideoLabel);
          if (button.dataset.videoLabelKey)
            video.setAttribute('data-i18n-attr-aria-label', button.dataset.videoLabelKey);
          if (title) {
            title.textContent = nextTitle;
            if (button.dataset.titleKey) title.setAttribute('data-i18n-key', button.dataset.titleKey);
          }
          if (description) {
            description.textContent = nextDescription;
            if (button.dataset.descriptionKey) description.setAttribute('data-i18n-key', button.dataset.descriptionKey);
          }
          playVideo(video);
        };

        buttons.forEach((button) => {
          button.addEventListener('click', () => selectDemo(button));
        });

        if (playButton instanceof HTMLButtonElement && video instanceof HTMLVideoElement) {
          playButton.addEventListener('click', () => playVideo(video));
        }
      });
    };

    document.addEventListener('astro:page-load', initMviDemo);
    initMviDemo();
  </script>
</Layout>
