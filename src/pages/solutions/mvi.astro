---
import { Icon } from 'astro-icon/components';

import Layout from '~/layouts/PageLayout.astro';

import inspectThumbnail from '~/assets/images/mvi/mvi_inspect_thumbnail.png';
import augmentGoodThumbnail from '~/assets/images/mvi/mvi_augment_gd_thumbnail.png';
import augmentDefectThumbnail from '~/assets/images/mvi/mvi_augment_defect_thumbnail.png';
import mviEvidence from '~/assets/images/refs/mvi-defect-evidence.png';
import inspectVideo from '~/assets/video/3_inspect.mp4';
import augmentGoodVideo from '~/assets/video/4_augment_ng_to_gd.mp4';
import augmentDefectVideo from '~/assets/video/5_augment_gd_to_burr.mp4';

const metadata = {
  title: 'MVI - Meta Vision AI',
  description:
    'MVI is MetaIntelligence manufacturing vision AI for one-class anomaly detection, GenAI augmentation, and field-adaptive inspection workflows.',
};

const valueProps = [
  {
    title: 'Ready-to-Run',
    description: 'Start from normal production images and reduce the dependency on large initial defect datasets.',
    icon: 'tabler:player-play',
  },
  {
    title: 'Expert-Free Operation',
    description:
      'Combine 3-BIN review, human feedback, and structured retraining so operators can keep improving the workflow.',
    icon: 'tabler:user-check',
  },
  {
    title: 'Field-Adaptive',
    description: 'Account for line changes, lighting shifts, and inspection feedback as part of the product workflow.',
    icon: 'tabler:adjustments',
  },
];

const pipeline = [
  ['01', 'Optical and Data Gate', 'Check imaging conditions, line context, and data readiness before model training.'],
  [
    '02',
    'One-Class Detection',
    'Detect anomaly candidates from normal-data-based learning and surface uncertain regions.',
  ],
  ['03', 'Targeted Augmentation', 'Use generative augmentation to enrich scarce defect and product-state examples.'],
  [
    '04',
    '3-BIN Operation',
    'Separate normal, uncertain, and defect cases while routing feedback into the learning loop.',
  ],
];

const demos = [
  {
    title: 'Defect inspection',
    description: 'Review anomaly candidates, heatmap output, and defect metadata in the inspection workflow.',
    video: inspectVideo,
    poster: inspectThumbnail,
    icon: 'tabler:scan-eye',
  },
  {
    title: 'Defect-to-good augmentation',
    description: 'Convert scarce defect examples into additional good-state training images for comparison.',
    video: augmentGoodVideo,
    poster: augmentGoodThumbnail,
    icon: 'tabler:sparkles',
  },
  {
    title: 'Good-to-defect augmentation',
    description: 'Generate targeted defect-like examples from normal imagery to close the early data gap.',
    video: augmentDefectVideo,
    poster: augmentDefectThumbnail,
    icon: 'tabler:wand',
  },
];

const initialDemo = demos[0];
---

<Layout metadata={metadata}>
  <section class="not-prose bg-white py-16 dark:bg-slate-950 md:py-24">
    <div class="mx-auto grid max-w-7xl gap-12 px-4 sm:px-6 lg:grid-cols-[0.9fr_1.1fr] lg:items-center">
      <div>
        <p class="text-sm font-bold uppercase tracking-wide text-emerald-700 dark:text-emerald-300">
          MVI / Meta Vision AI
        </p>
        <h1 class="mt-4 text-4xl font-bold tracking-tight text-slate-950 dark:text-white md:text-6xl">
          Vision AI for manufacturing lines where defect data is scarce
        </h1>
        <p class="mt-6 text-lg leading-relaxed text-slate-600 dark:text-slate-300 md:text-xl">
          MVI connects one-class anomaly detection, targeted data augmentation, and review operation into a workflow
          that can be adapted to real inspection environments.
        </p>
        <div class="mt-8 grid gap-3 sm:grid-cols-3">
          {
            ['One-Class', 'GenAI', '3-BIN'].map((item) => (
              <div class="border border-slate-200 p-4 dark:border-slate-800">
                <strong class="block text-slate-950 dark:text-white">{item}</strong>
                <span class="mt-1 block text-sm text-slate-500 dark:text-slate-400">inspection workflow</span>
              </div>
            ))
          }
        </div>
      </div>
      <div
        class="overflow-hidden border border-slate-200 bg-slate-950 shadow-2xl shadow-slate-200 dark:border-slate-800 dark:shadow-none"
      >
        <video
          class="aspect-video w-full object-cover"
          src={inspectVideo}
          poster={inspectThumbnail.src}
          autoplay
          loop
          muted
          playsinline
          controls
          preload="metadata"
          aria-label="MVI defect inspection demo"></video>
      </div>
    </div>
  </section>

  <section class="not-prose bg-slate-50 py-16 dark:bg-slate-900 md:py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6">
      <div class="grid gap-5 md:grid-cols-3">
        {
          valueProps.map((item) => (
            <article class="border border-slate-200 bg-white p-7 dark:border-slate-800 dark:bg-slate-950">
              <Icon name={item.icon} class="h-9 w-9 text-emerald-700 dark:text-emerald-300" />
              <h2 class="mt-6 text-2xl font-bold text-slate-950 dark:text-white">{item.title}</h2>
              <p class="mt-4 leading-relaxed text-slate-600 dark:text-slate-300">{item.description}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="not-prose bg-white py-16 dark:bg-slate-950 md:py-24">
    <div class="mx-auto grid max-w-7xl gap-12 px-4 sm:px-6 lg:grid-cols-[0.8fr_1.2fr] lg:items-center">
      <div>
        <p class="text-sm font-bold uppercase tracking-wide text-emerald-700 dark:text-emerald-300">Visual Evidence</p>
        <h2 class="mt-3 text-3xl font-bold tracking-tight text-slate-950 dark:text-white md:text-5xl">
          Inspection output is treated as reviewable evidence
        </h2>
        <p class="mt-5 text-lg leading-relaxed text-slate-600 dark:text-slate-300">
          MVI is framed as a production workflow: gather normal images, augment scarce cases, inspect candidates, and
          route uncertain results back into review.
        </p>
      </div>
      <figure class="border border-slate-200 bg-slate-50 p-4 dark:border-slate-800 dark:bg-slate-900">
        <img
          src={mviEvidence.src}
          width={mviEvidence.width}
          height={mviEvidence.height}
          alt="MVI defect example and heatmap evidence"
          class="w-full object-cover"
          loading="lazy"
        />
      </figure>
    </div>
  </section>

  <section class="not-prose bg-slate-50 py-16 dark:bg-slate-900 md:py-24">
    <div class="mx-auto grid max-w-7xl gap-12 px-4 sm:px-6 lg:grid-cols-[0.75fr_1.25fr]">
      <div>
        <p class="text-sm font-bold uppercase tracking-wide text-emerald-700 dark:text-emerald-300">
          Operating Pipeline
        </p>
        <h2 class="mt-3 text-3xl font-bold tracking-tight text-slate-950 dark:text-white md:text-5xl">
          More than a detector: a production feedback loop
        </h2>
      </div>
      <div class="space-y-4">
        {
          pipeline.map(([label, title, description]) => (
            <article class="grid gap-4 border border-slate-200 bg-white p-5 dark:border-slate-800 dark:bg-slate-950 sm:grid-cols-[80px_1fr]">
              <div class="font-bold text-emerald-700 dark:text-emerald-300">{label}</div>
              <div>
                <h3 class="font-bold text-slate-950 dark:text-white">{title}</h3>
                <p class="mt-2 text-sm leading-relaxed text-slate-600 dark:text-slate-300">{description}</p>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="not-prose bg-slate-950 py-16 text-white md:py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6">
      <div class="max-w-3xl">
        <p class="text-sm font-bold uppercase tracking-wide text-emerald-200">Product Demos</p>
        <h2 class="mt-3 text-3xl font-bold tracking-tight md:text-5xl">Select a workflow step and play the demo</h2>
        <p class="mt-5 leading-relaxed text-slate-300">
          The selected video updates in place so each workflow step can be reviewed without crowding the page.
        </p>
      </div>

      <div class="mt-10 grid gap-6 lg:grid-cols-[340px_1fr]" data-mvi-demo>
        <div class="space-y-3">
          {
            demos.map((demo, index) => (
              <button
                type="button"
                class="group w-full border border-white/10 bg-white/[0.04] p-4 text-left transition hover:border-emerald-300 hover:bg-white/[0.08] aria-pressed:border-emerald-300 aria-pressed:bg-white/[0.1]"
                aria-pressed={index === 0 ? 'true' : 'false'}
                data-mvi-demo-button
                data-video={demo.video}
                data-poster={demo.poster.src}
                data-title={demo.title}
                data-description={demo.description}
              >
                <span class="grid grid-cols-[96px_1fr] gap-4">
                  <span class="relative block bg-black">
                    <img
                      src={demo.poster.src}
                      width={demo.poster.width}
                      height={demo.poster.height}
                      alt={`${demo.title} thumbnail`}
                      class="aspect-video h-full w-full object-cover"
                      loading="lazy"
                    />
                    <span class="absolute inset-0 flex items-center justify-center bg-black/20">
                      <Icon name={demo.icon} class="h-6 w-6 text-emerald-200" />
                    </span>
                  </span>
                  <span class="min-w-0">
                    <span class="block font-bold text-white">{demo.title}</span>
                    <span class="mt-2 block text-sm leading-relaxed text-slate-300">{demo.description}</span>
                  </span>
                </span>
              </button>
            ))
          }
        </div>

        <article class="overflow-hidden border border-white/10 bg-white/[0.04]">
          <video
            class="aspect-video w-full bg-black object-contain"
            src={initialDemo.video}
            poster={initialDemo.poster.src}
            muted
            playsinline
            controls
            preload="metadata"
            data-mvi-video
            aria-label={`MVI ${initialDemo.title} demo`}></video>
          <div class="border-t border-white/10 p-5 md:p-6">
            <div class="flex flex-col gap-5 md:flex-row md:items-start">
              <button
                type="button"
                class="inline-flex shrink-0 items-center justify-center gap-2 bg-emerald-300 px-4 py-3 text-sm font-bold text-slate-950 transition hover:bg-emerald-200"
                data-mvi-play
              >
                <Icon name="tabler:player-play-filled" class="h-5 w-5" />
                Play
              </button>
              <div>
                <h3 class="text-xl font-bold" data-mvi-title>{initialDemo.title}</h3>
                <p class="mt-2 leading-relaxed text-slate-300" data-mvi-description>{initialDemo.description}</p>
              </div>
            </div>
          </div>
        </article>
      </div>
    </div>
  </section>

  <script>
    const playVideo = (video: Element | null) => {
      if (!(video instanceof HTMLVideoElement)) return;
      video.muted = true;
      const playPromise = video.play();
      if (playPromise && typeof playPromise.catch === 'function') {
        playPromise.catch(() => {});
      }
    };

    const initMviDemo = () => {
      document.querySelectorAll('[data-mvi-demo]').forEach((root) => {
        if (root.getAttribute('data-bound') === 'true') return;
        root.setAttribute('data-bound', 'true');

        const video = root.querySelector('[data-mvi-video]');
        const playButton = root.querySelector('[data-mvi-play]');
        const title = root.querySelector('[data-mvi-title]');
        const description = root.querySelector('[data-mvi-description]');
        const buttons = Array.from(root.querySelectorAll('[data-mvi-demo-button]'));

        const selectDemo = (button: Element) => {
          if (!(button instanceof HTMLElement) || !(video instanceof HTMLVideoElement)) return;

          buttons.forEach((item) => item.setAttribute('aria-pressed', item === button ? 'true' : 'false'));

          const nextVideo = button.dataset.video;
          const nextPoster = button.dataset.poster;
          const nextTitle = button.dataset.title || '';
          const nextDescription = button.dataset.description || '';

          if (nextVideo && video.getAttribute('src') !== nextVideo) {
            video.pause();
            video.setAttribute('src', nextVideo);
            if (nextPoster) video.setAttribute('poster', nextPoster);
            video.load();
          }

          video.setAttribute('aria-label', `MVI ${nextTitle} demo`);
          if (title) title.textContent = nextTitle;
          if (description) description.textContent = nextDescription;
          playVideo(video);
        };

        buttons.forEach((button) => {
          button.addEventListener('click', () => selectDemo(button));
        });

        if (playButton instanceof HTMLButtonElement && video instanceof HTMLVideoElement) {
          playButton.addEventListener('click', () => playVideo(video));
        }
      });
    };

    document.addEventListener('astro:page-load', initMviDemo);
    initMviDemo();
  </script>
</Layout>
