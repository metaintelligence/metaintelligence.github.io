---
import { Icon } from 'astro-icon/components';

import Layout from '~/layouts/PageLayout.astro';
import { createTranslator } from '~/utils/i18n';
import overviewScreen from '~/assets/images/ida/ida_result_overview.png';
import chartsScreen from '~/assets/images/ida/ida_result_charts.png';
import detailScreen from '~/assets/images/ida/ida_item_detail.png';
import insightsScreen from '~/assets/images/ida/ida_insights.png';

const t = createTranslator();

const metadata = {
  title: t('pages.metainsight.metaTitle'),
  description: t('pages.metainsight.metaDescription'),
};

const workflow = [
  ['01', 'collect'],
  ['02', 'cluster'],
  ['03', 'score'],
  ['04', 'insights'],
];

const screens = [
  {
    key: 'overview',
    image: overviewScreen,
  },
  {
    key: 'charts',
    image: chartsScreen,
  },
  {
    key: 'details',
    image: detailScreen,
  },
  {
    key: 'insights',
    image: insightsScreen,
  },
];

const firstScreen = screens[0];
---

<Layout metadata={metadata}>
  <section class="not-prose bg-white py-16 dark:bg-slate-950 md:py-24">
    <div class="mx-auto grid max-w-7xl gap-12 px-4 sm:px-6 lg:grid-cols-[0.9fr_1.1fr] lg:items-center">
      <div>
        <p
          class="text-sm font-bold uppercase tracking-wide text-blue-700 dark:text-blue-300"
          data-i18n-key="pages.metainsight.eyebrow"
        >
          {t('pages.metainsight.eyebrow')}
        </p>
        <h1
          class="mt-4 text-4xl font-bold tracking-tight text-slate-950 dark:text-white md:text-6xl"
          data-i18n-key="pages.metainsight.title"
        >
          {t('pages.metainsight.title')}
        </h1>
        <p
          class="mt-6 text-lg leading-relaxed text-slate-600 dark:text-slate-300 md:text-xl"
          data-i18n-key="pages.metainsight.description"
        >
          {t('pages.metainsight.description')}
        </p>
        <div class="mt-8 grid gap-3 sm:grid-cols-3">
          <div class="border border-slate-200 p-4 dark:border-slate-800">
            <strong class="block text-slate-950 dark:text-white">6.5M+</strong>
            <span class="mt-1 block text-sm text-slate-500" data-i18n-key="pages.metainsight.stats.records">
              {t('pages.metainsight.stats.records')}
            </span>
          </div>
          <div class="border border-slate-200 p-4 dark:border-slate-800">
            <strong class="block text-slate-950 dark:text-white" data-i18n-key="pages.metainsight.stats.configValue">
              {t('pages.metainsight.stats.configValue')}
            </strong>
            <span class="mt-1 block text-sm text-slate-500" data-i18n-key="pages.metainsight.stats.config">
              {t('pages.metainsight.stats.config')}
            </span>
          </div>
          <div class="border border-slate-200 p-4 dark:border-slate-800">
            <strong class="block text-slate-950 dark:text-white" data-i18n-key="pages.metainsight.stats.signalsValue">
              {t('pages.metainsight.stats.signalsValue')}
            </strong>
            <span class="mt-1 block text-sm text-slate-500" data-i18n-key="pages.metainsight.stats.signals">
              {t('pages.metainsight.stats.signals')}
            </span>
          </div>
        </div>
      </div>
      <div
        class="overflow-hidden border border-slate-200 bg-slate-950 shadow-2xl shadow-slate-200 dark:border-slate-800 dark:shadow-none"
      >
        <img
          src={overviewScreen.src}
          width={overviewScreen.width}
          height={overviewScreen.height}
          alt={t('pages.metainsight.heroAlt')}
          data-i18n-attrs="alt"
          data-i18n-attr-alt="pages.metainsight.heroAlt"
          class="aspect-[16/10] w-full object-cover object-top"
          loading="eager"
        />
      </div>
    </div>
  </section>

  <section class="not-prose bg-slate-50 py-16 dark:bg-slate-900 md:py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6">
      <div class="max-w-3xl">
        <p
          class="text-sm font-bold uppercase tracking-wide text-blue-700 dark:text-blue-300"
          data-i18n-key="pages.metainsight.workflowEyebrow"
        >
          {t('pages.metainsight.workflowEyebrow')}
        </p>
        <h2
          class="mt-3 text-3xl font-bold tracking-tight text-slate-950 dark:text-white md:text-5xl"
          data-i18n-key="pages.metainsight.workflowTitle"
        >
          {t('pages.metainsight.workflowTitle')}
        </h2>
      </div>
      <div class="mt-10 grid gap-4 md:grid-cols-4">
        {
          workflow.map(([label, key]) => (
            <article class="border border-slate-200 bg-white p-6 dark:border-slate-800 dark:bg-slate-950">
              <span class="text-xs font-bold text-blue-700 dark:text-blue-300">{label}</span>
              <h3
                class="mt-4 text-xl font-bold text-slate-950 dark:text-white"
                data-i18n-key={`pages.metainsight.workflow.${key}.title`}
              >
                {t(`pages.metainsight.workflow.${key}.title`)}
              </h3>
              <p
                class="mt-3 text-sm leading-relaxed text-slate-600 dark:text-slate-300"
                data-i18n-key={`pages.metainsight.workflow.${key}.description`}
              >
                {t(`pages.metainsight.workflow.${key}.description`)}
              </p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="not-prose bg-white py-16 dark:bg-slate-950 md:py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6">
      <div class="max-w-3xl">
        <p
          class="text-sm font-bold uppercase tracking-wide text-blue-700 dark:text-blue-300"
          data-i18n-key="pages.metainsight.screensEyebrow"
        >
          {t('pages.metainsight.screensEyebrow')}
        </p>
        <h2
          class="mt-3 text-3xl font-bold tracking-tight text-slate-950 dark:text-white md:text-5xl"
          data-i18n-key="pages.metainsight.screensTitle"
        >
          {t('pages.metainsight.screensTitle')}
        </h2>
        <p
          class="mt-5 leading-relaxed text-slate-600 dark:text-slate-300"
          data-i18n-key="pages.metainsight.screensDescription"
        >
          {t('pages.metainsight.screensDescription')}
        </p>
      </div>

      <div class="mt-10 grid gap-8 lg:grid-cols-[320px_1fr]" data-metainsight-gallery>
        <div class="space-y-3">
          {
            screens.map((screen, index) => (
              <button
                type="button"
                class="w-full border border-slate-200 bg-white p-5 text-left transition hover:border-blue-300 hover:bg-slate-50 aria-pressed:border-slate-950 aria-pressed:bg-slate-950 aria-pressed:text-white dark:border-slate-800 dark:bg-slate-950 dark:hover:border-blue-500 dark:aria-pressed:border-blue-300 dark:aria-pressed:bg-blue-950"
                aria-pressed={index === 0 ? 'true' : 'false'}
                data-screen-button
                data-image={screen.image.src}
                data-alt={t(`pages.metainsight.screens.${screen.key}.alt`)}
                data-title={t(`pages.metainsight.screens.${screen.key}.title`)}
                data-description={t(`pages.metainsight.screens.${screen.key}.description`)}
                data-title-key={`pages.metainsight.screens.${screen.key}.title`}
                data-description-key={`pages.metainsight.screens.${screen.key}.description`}
                data-alt-key={`pages.metainsight.screens.${screen.key}.alt`}
                data-i18n-attrs="data-alt,data-title,data-description"
                data-i18n-attr-data-alt={`pages.metainsight.screens.${screen.key}.alt`}
                data-i18n-attr-data-title={`pages.metainsight.screens.${screen.key}.title`}
                data-i18n-attr-data-description={`pages.metainsight.screens.${screen.key}.description`}
              >
                <span class="text-xs font-bold text-blue-700 aria-pressed:text-blue-200 dark:text-blue-300">
                  0{index + 1}
                </span>
                <span class="mt-2 block font-bold" data-i18n-key={`pages.metainsight.screens.${screen.key}.title`}>
                  {t(`pages.metainsight.screens.${screen.key}.title`)}
                </span>
                <span
                  class="mt-2 block text-sm leading-relaxed text-slate-500 dark:text-slate-400"
                  data-i18n-key={`pages.metainsight.screens.${screen.key}.description`}
                >
                  {t(`pages.metainsight.screens.${screen.key}.description`)}
                </span>
              </button>
            ))
          }
        </div>
        <div class="overflow-hidden border border-slate-200 bg-slate-950 dark:border-slate-800">
          <img
            src={firstScreen.image.src}
            width={firstScreen.image.width}
            height={firstScreen.image.height}
            alt={t(`pages.metainsight.screens.${firstScreen.key}.alt`)}
            data-i18n-attrs="alt"
            data-i18n-attr-alt={`pages.metainsight.screens.${firstScreen.key}.alt`}
            class="aspect-[16/10] w-full object-cover object-top"
            data-screen-image
            loading="lazy"
          />
          <div class="border-t border-white/10 bg-slate-950 p-5 text-white">
            <h3
              class="text-xl font-bold"
              data-screen-title
              data-i18n-key={`pages.metainsight.screens.${firstScreen.key}.title`}
            >
              {t(`pages.metainsight.screens.${firstScreen.key}.title`)}
            </h3>
            <p
              class="mt-2 text-sm leading-relaxed text-slate-300"
              data-screen-description
              data-i18n-key={`pages.metainsight.screens.${firstScreen.key}.description`}
            >
              {t(`pages.metainsight.screens.${firstScreen.key}.description`)}
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="not-prose bg-slate-950 py-16 text-white md:py-24">
    <div class="mx-auto grid max-w-7xl gap-10 px-4 sm:px-6 lg:grid-cols-[0.8fr_1.2fr]">
      <div>
        <p
          class="text-sm font-bold uppercase tracking-wide text-blue-200"
          data-i18n-key="pages.metainsight.differentiationEyebrow"
        >
          {t('pages.metainsight.differentiationEyebrow')}
        </p>
        <h2
          class="mt-3 text-3xl font-bold tracking-tight md:text-5xl"
          data-i18n-key="pages.metainsight.differentiationTitle"
        >
          {t('pages.metainsight.differentiationTitle')}
        </h2>
      </div>
      <div class="grid gap-4 md:grid-cols-3">
        {
          ['quant', 'repeatable', 'extension'].map((key) => (
            <article class="border border-white/10 bg-white/[0.03] p-6">
              <Icon name="tabler:check" class="h-6 w-6 text-blue-200" />
              <h3 class="mt-5 font-bold" data-i18n-key={`pages.metainsight.differentiation.${key}.title`}>
                {t(`pages.metainsight.differentiation.${key}.title`)}
              </h3>
              <p
                class="mt-3 text-sm leading-relaxed text-slate-300"
                data-i18n-key={`pages.metainsight.differentiation.${key}.description`}
              >
                {t(`pages.metainsight.differentiation.${key}.description`)}
              </p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <script>
    const initMetaInsightGallery = () => {
      document.querySelectorAll('[data-metainsight-gallery]').forEach((gallery) => {
        if (gallery.getAttribute('data-bound') === 'true') return;
        gallery.setAttribute('data-bound', 'true');

        const image = gallery.querySelector('[data-screen-image]');
        const title = gallery.querySelector('[data-screen-title]');
        const description = gallery.querySelector('[data-screen-description]');
        const buttons = Array.from(gallery.querySelectorAll('[data-screen-button]'));

        buttons.forEach((button) => {
          button.addEventListener('click', () => {
            buttons.forEach((item) => item.setAttribute('aria-pressed', 'false'));
            button.setAttribute('aria-pressed', 'true');

            if (image instanceof HTMLImageElement && button instanceof HTMLElement) {
              image.src = button.dataset.image || image.src;
              image.alt = button.dataset.alt || image.alt;
              if (button.dataset.altKey) image.setAttribute('data-i18n-attr-alt', button.dataset.altKey);
            }
            if (title) {
              title.textContent = button instanceof HTMLElement ? button.dataset.title || '' : '';
              if (button instanceof HTMLElement && button.dataset.titleKey) {
                title.setAttribute('data-i18n-key', button.dataset.titleKey);
              }
            }
            if (description) {
              description.textContent = button instanceof HTMLElement ? button.dataset.description || '' : '';
              if (button instanceof HTMLElement && button.dataset.descriptionKey) {
                description.setAttribute('data-i18n-key', button.dataset.descriptionKey);
              }
            }
          });
        });
      });
    };

    document.addEventListener('astro:page-load', initMetaInsightGallery);
    initMetaInsightGallery();
  </script>
</Layout>
