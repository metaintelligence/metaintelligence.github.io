---
import { Icon } from 'astro-icon/components';

import Layout from '~/layouts/PageLayout.astro';
import overviewScreen from '~/assets/images/ida/ida_result_overview.png';
import chartsScreen from '~/assets/images/ida/ida_result_charts.png';
import detailScreen from '~/assets/images/ida/ida_item_detail.png';
import insightsScreen from '~/assets/images/ida/ida_insights.png';

const metadata = {
  title: 'MetaInsight - R&D Intelligence Platform',
  description:
    'MetaInsight is MetaIntelligence R&D intelligence platform for data cleansing, clustering, trend scoring, and verified report generation.',
};

const workflow = [
  [
    '01',
    'Collect & Cleanse',
    'Normalize global R&D records, resolve missing fields, and prepare analysis-ready datasets.',
  ],
  [
    '02',
    'Vectorize & Cluster',
    'Transform titles, abstracts, and keywords into semantic groups for technology exploration.',
  ],
  [
    '03',
    'Score Signals',
    'Compare funding, recency, cluster momentum, and organization signals for quantitative review.',
  ],
  [
    '04',
    'Generate Reports',
    'Create evidence-linked summaries and analyst-ready report drafts from structured results.',
  ],
];

const screens = [
  {
    title: 'Overview',
    image: overviewScreen,
    description: 'Review the total result set, representative clusters, and high-level signal distribution.',
  },
  {
    title: 'Charts',
    image: chartsScreen,
    description: 'Inspect rankings, distribution patterns, and group comparisons through focused charts.',
  },
  {
    title: 'Details',
    image: detailScreen,
    description: 'Move from a cluster-level insight back to individual records and source-level evidence.',
  },
  {
    title: 'Insights',
    image: insightsScreen,
    description: 'Convert analysis outputs into concise, reviewable intelligence statements.',
  },
];

const firstScreen = screens[0];
---

<Layout metadata={metadata}>
  <section class="not-prose bg-white py-16 dark:bg-slate-950 md:py-24">
    <div class="mx-auto grid max-w-7xl gap-12 px-4 sm:px-6 lg:grid-cols-[0.9fr_1.1fr] lg:items-center">
      <div>
        <p class="text-sm font-bold uppercase tracking-wide text-blue-700 dark:text-blue-300">MetaInsight</p>
        <h1 class="mt-4 text-4xl font-bold tracking-tight text-slate-950 dark:text-white md:text-6xl">
          R&D intelligence from large datasets to reviewable decisions
        </h1>
        <p class="mt-6 text-lg leading-relaxed text-slate-600 dark:text-slate-300 md:text-xl">
          MetaInsight collects and structures R&D data, identifies technology clusters, evaluates emerging signals, and
          keeps generated summaries linked to evidence.
        </p>
        <div class="mt-8 grid gap-3 sm:grid-cols-3">
          <div class="border border-slate-200 p-4 dark:border-slate-800">
            <strong class="block text-slate-950 dark:text-white">6.5M+</strong>
            <span class="mt-1 block text-sm text-slate-500">R&D records processed</span>
          </div>
          <div class="border border-slate-200 p-4 dark:border-slate-800">
            <strong class="block text-slate-950 dark:text-white">4 years</strong>
            <span class="mt-1 block text-sm text-slate-500">Repeated analytics execution</span>
          </div>
          <div class="border border-slate-200 p-4 dark:border-slate-800">
            <strong class="block text-slate-950 dark:text-white">Report</strong>
            <span class="mt-1 block text-sm text-slate-500">Evidence-linked output</span>
          </div>
        </div>
      </div>
      <div
        class="overflow-hidden border border-slate-200 bg-slate-950 shadow-2xl shadow-slate-200 dark:border-slate-800 dark:shadow-none"
      >
        <img
          src={overviewScreen.src}
          width={overviewScreen.width}
          height={overviewScreen.height}
          alt="MetaInsight result overview"
          class="aspect-[16/10] w-full object-cover object-top"
          loading="eager"
        />
      </div>
    </div>
  </section>

  <section class="not-prose bg-slate-50 py-16 dark:bg-slate-900 md:py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6">
      <div class="max-w-3xl">
        <p class="text-sm font-bold uppercase tracking-wide text-blue-700 dark:text-blue-300">Workflow</p>
        <h2 class="mt-3 text-3xl font-bold tracking-tight text-slate-950 dark:text-white md:text-5xl">
          One flow from collection to report
        </h2>
      </div>
      <div class="mt-10 grid gap-4 md:grid-cols-4">
        {
          workflow.map(([label, title, description]) => (
            <article class="border border-slate-200 bg-white p-6 dark:border-slate-800 dark:bg-slate-950">
              <span class="text-xs font-bold text-blue-700 dark:text-blue-300">{label}</span>
              <h3 class="mt-4 text-xl font-bold text-slate-950 dark:text-white">{title}</h3>
              <p class="mt-3 text-sm leading-relaxed text-slate-600 dark:text-slate-300">{description}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="not-prose bg-white py-16 dark:bg-slate-950 md:py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6">
      <div class="max-w-3xl">
        <p class="text-sm font-bold uppercase tracking-wide text-blue-700 dark:text-blue-300">Screens</p>
        <h2 class="mt-3 text-3xl font-bold tracking-tight text-slate-950 dark:text-white md:text-5xl">
          A focused screen tour with selectable evidence
        </h2>
        <p class="mt-5 leading-relaxed text-slate-600 dark:text-slate-300">
          Select the screen that matches the analysis task. The image below updates in place so the page stays concise.
        </p>
      </div>

      <div class="mt-10 grid gap-8 lg:grid-cols-[320px_1fr]" data-metainsight-gallery>
        <div class="space-y-3">
          {
            screens.map((screen, index) => (
              <button
                type="button"
                class="w-full border border-slate-200 bg-white p-5 text-left transition hover:border-blue-300 hover:bg-slate-50 aria-pressed:border-slate-950 aria-pressed:bg-slate-950 aria-pressed:text-white dark:border-slate-800 dark:bg-slate-950 dark:hover:border-blue-500 dark:aria-pressed:border-blue-300 dark:aria-pressed:bg-blue-950"
                aria-pressed={index === 0 ? 'true' : 'false'}
                data-screen-button
                data-image={screen.image.src}
                data-alt={`MetaInsight ${screen.title} screen`}
                data-title={screen.title}
                data-description={screen.description}
              >
                <span class="text-xs font-bold text-blue-700 aria-pressed:text-blue-200 dark:text-blue-300">
                  0{index + 1}
                </span>
                <span class="mt-2 block font-bold">{screen.title}</span>
                <span class="mt-2 block text-sm leading-relaxed text-slate-500 dark:text-slate-400">
                  {screen.description}
                </span>
              </button>
            ))
          }
        </div>
        <div class="overflow-hidden border border-slate-200 bg-slate-950 dark:border-slate-800">
          <img
            src={firstScreen.image.src}
            width={firstScreen.image.width}
            height={firstScreen.image.height}
            alt={`MetaInsight ${firstScreen.title} screen`}
            class="aspect-[16/10] w-full object-cover object-top"
            data-screen-image
            loading="lazy"
          />
          <div class="border-t border-white/10 bg-slate-950 p-5 text-white">
            <h3 class="text-xl font-bold" data-screen-title>{firstScreen.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-slate-300" data-screen-description>{firstScreen.description}</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="not-prose bg-slate-950 py-16 text-white md:py-24">
    <div class="mx-auto grid max-w-7xl gap-10 px-4 sm:px-6 lg:grid-cols-[0.8fr_1.2fr]">
      <div>
        <p class="text-sm font-bold uppercase tracking-wide text-blue-200">Differentiation</p>
        <h2 class="mt-3 text-3xl font-bold tracking-tight md:text-5xl">
          A bridge between analysis tools and final reports
        </h2>
      </div>
      <div class="grid gap-4 md:grid-cols-3">
        {
          [
            ['Quant evidence', 'Signals are explained through cluster scores, trends, and source records.'],
            [
              'Repeatable exploration',
              'Analysts can change country, field, period, and organization filters without rebuilding work.',
            ],
            [
              'Domain extension',
              'The same structure can support R&D, manufacturing reports, and technical document intelligence.',
            ],
          ].map(([title, description]) => (
            <article class="border border-white/10 bg-white/[0.03] p-6">
              <Icon name="tabler:check" class="h-6 w-6 text-blue-200" />
              <h3 class="mt-5 font-bold">{title}</h3>
              <p class="mt-3 text-sm leading-relaxed text-slate-300">{description}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <script>
    const initMetaInsightGallery = () => {
      document.querySelectorAll('[data-metainsight-gallery]').forEach((gallery) => {
        if (gallery.getAttribute('data-bound') === 'true') return;
        gallery.setAttribute('data-bound', 'true');

        const image = gallery.querySelector('[data-screen-image]');
        const title = gallery.querySelector('[data-screen-title]');
        const description = gallery.querySelector('[data-screen-description]');
        const buttons = Array.from(gallery.querySelectorAll('[data-screen-button]'));

        buttons.forEach((button) => {
          button.addEventListener('click', () => {
            buttons.forEach((item) => item.setAttribute('aria-pressed', 'false'));
            button.setAttribute('aria-pressed', 'true');

            if (image instanceof HTMLImageElement && button instanceof HTMLElement) {
              image.src = button.dataset.image || image.src;
              image.alt = button.dataset.alt || image.alt;
            }
            if (title) title.textContent = button instanceof HTMLElement ? button.dataset.title || '' : '';
            if (description) {
              description.textContent = button instanceof HTMLElement ? button.dataset.description || '' : '';
            }
          });
        });
      });
    };

    document.addEventListener('astro:page-load', initMetaInsightGallery);
    initMetaInsightGallery();
  </script>
</Layout>
