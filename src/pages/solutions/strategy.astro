---
import { Icon } from 'astro-icon/components';

import Layout from '~/layouts/PageLayout.astro';
import { collaborationSolutions, solutions } from '~/data/site';
import { getPermalink } from '~/utils/permalinks';

const metadata = {
  title: 'Solution Strategy',
  description: 'MetaIntelligence solution strategy across flagship products and collaboration extensions.',
};

const phases = [
  {
    title: 'Prove the method through repeated work',
    description:
      'Public R&D analytics projects validated the foundation for data cleansing, clustering, signal analysis, and report workflows.',
  },
  {
    title: 'Convert research into product lines',
    description:
      'MetaInsight and MVI organize the verified methods into repeatable software products rather than one-off demonstrations.',
  },
  {
    title: 'Extend selectively into adjacent domains',
    description:
      'Manufacturing report automation, real-time visual tracking, and agentic analysis are presented as focused extensions.',
  },
];
---

<Layout metadata={metadata}>
  <section id="portfolio" class="not-prose bg-white py-16 dark:bg-slate-950 md:py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6">
      <div class="max-w-4xl">
        <p class="text-sm font-bold uppercase tracking-wide text-blue-700 dark:text-blue-300">Strategy</p>
        <h1 class="mt-4 text-4xl font-bold tracking-tight text-slate-950 dark:text-white md:text-6xl">
          Turning verified technical work into focused product lines
        </h1>
        <p class="mt-6 text-lg leading-relaxed text-slate-600 dark:text-slate-300 md:text-xl">
          MetaIntelligence avoids presenting every possible AI idea as a product. The portfolio is organized around work
          that has a clear data foundation, operating workflow, and path to deployment.
        </p>
      </div>
    </div>
  </section>

  <section class="not-prose bg-slate-50 py-16 dark:bg-slate-900 md:py-24">
    <div class="mx-auto grid max-w-7xl gap-5 px-4 sm:px-6 md:grid-cols-3">
      {
        phases.map((phase, index) => (
          <article class="border border-slate-200 bg-white p-7 dark:border-slate-800 dark:bg-slate-950">
            <span class="text-xs font-bold text-blue-700 dark:text-blue-300">{String(index + 1).padStart(2, '0')}</span>
            <h2 class="mt-5 text-2xl font-bold text-slate-950 dark:text-white">{phase.title}</h2>
            <p class="mt-4 leading-relaxed text-slate-600 dark:text-slate-300">{phase.description}</p>
          </article>
        ))
      }
    </div>
  </section>

  <section class="not-prose bg-white py-16 dark:bg-slate-950 md:py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6">
      <div class="max-w-3xl">
        <p class="text-sm font-bold uppercase tracking-wide text-blue-700 dark:text-blue-300">Portfolio</p>
        <h2 class="mt-3 text-3xl font-bold tracking-tight text-slate-950 dark:text-white md:text-5xl">
          Public solution portfolio
        </h2>
      </div>
      <div class="mt-10 grid gap-5 lg:grid-cols-3">
        {
          solutions.map((solution) => (
            <a
              href={getPermalink(solution.href)}
              class="block border border-slate-200 p-7 transition hover:-translate-y-1 hover:border-cyan-300 hover:bg-slate-50 dark:border-slate-800 dark:hover:border-cyan-500 dark:hover:bg-slate-900"
            >
              <Icon name={solution.icon} class="h-8 w-8 text-blue-700 dark:text-blue-300" />
              <p class="mt-6 text-sm font-semibold uppercase tracking-wide text-slate-500">{solution.domain}</p>
              <h3 class="mt-2 text-2xl font-bold text-slate-950 dark:text-white">{solution.name}</h3>
              <p class="mt-4 leading-relaxed text-slate-600 dark:text-slate-300">{solution.summary}</p>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <section class="not-prose bg-slate-950 py-16 text-white md:py-24">
    <div class="mx-auto grid max-w-7xl gap-12 px-4 sm:px-6 lg:grid-cols-[0.8fr_1.2fr]">
      <div>
        <p class="text-sm font-bold uppercase tracking-wide text-blue-200">Extensions</p>
        <h2 class="mt-3 text-3xl font-bold tracking-tight md:text-5xl">
          Collaboration directions, kept deliberately selective
        </h2>
        <p class="mt-5 leading-relaxed text-slate-300">
          Extension concepts are shown as technical direction and collaboration potential, separate from the flagship
          product lines.
        </p>
      </div>
      <div class="grid gap-4 md:grid-cols-2">
        {
          collaborationSolutions.map((item) => (
            <article class="border border-white/10 bg-white/[0.03] p-6">
              <p class="text-sm font-semibold text-blue-200">{item.domain}</p>
              <h3 class="mt-2 text-xl font-bold">{item.name}</h3>
              <p class="mt-3 text-sm leading-relaxed text-slate-300">{item.description}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>
</Layout>
