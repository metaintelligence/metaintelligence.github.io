---
import { Icon } from 'astro-icon/components';

import Layout from '~/layouts/PageLayout.astro';
import { collaborationSolutions, solutions } from '~/data/site';
import { createTranslator } from '~/utils/i18n';
import { getPermalink } from '~/utils/permalinks';

const t = createTranslator();

const metadata = {
  title: t('pages.strategy.metaTitle'),
  description: t('pages.strategy.metaDescription'),
};

const phases = ['prove', 'convert', 'extend'];
const collaborationKeys = ['metainsightMfg', 'aeroGimbal'];
---

<Layout metadata={metadata}>
  <section id="portfolio" class="not-prose bg-white py-16 dark:bg-slate-950 md:py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6">
      <div class="max-w-4xl">
        <p
          class="text-sm font-bold uppercase tracking-wide text-blue-700 dark:text-blue-300"
          data-i18n-key="pages.strategy.eyebrow"
        >
          {t('pages.strategy.eyebrow')}
        </p>
        <h1
          class="mt-4 text-4xl font-bold tracking-tight text-slate-950 dark:text-white md:text-6xl"
          data-i18n-key="pages.strategy.title"
        >
          {t('pages.strategy.title')}
        </h1>
        <p
          class="mt-6 text-lg leading-relaxed text-slate-600 dark:text-slate-300 md:text-xl"
          data-i18n-key="pages.strategy.description"
        >
          {t('pages.strategy.description')}
        </p>
      </div>
    </div>
  </section>

  <section class="not-prose bg-slate-50 py-16 dark:bg-slate-900 md:py-24">
    <div class="mx-auto grid max-w-7xl gap-5 px-4 sm:px-6 md:grid-cols-3">
      {
        phases.map((phase, index) => (
          <article class="border border-slate-200 bg-white p-7 dark:border-slate-800 dark:bg-slate-950">
            <span class="text-xs font-bold text-blue-700 dark:text-blue-300">{String(index + 1).padStart(2, '0')}</span>
            <h2
              class="mt-5 text-2xl font-bold text-slate-950 dark:text-white"
              data-i18n-key={`pages.strategy.phases.${phase}.title`}
            >
              {t(`pages.strategy.phases.${phase}.title`)}
            </h2>
            <p
              class="mt-4 leading-relaxed text-slate-600 dark:text-slate-300"
              data-i18n-key={`pages.strategy.phases.${phase}.description`}
            >
              {t(`pages.strategy.phases.${phase}.description`)}
            </p>
          </article>
        ))
      }
    </div>
  </section>

  <section class="not-prose bg-white py-16 dark:bg-slate-950 md:py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6">
      <div class="max-w-3xl">
        <p
          class="text-sm font-bold uppercase tracking-wide text-blue-700 dark:text-blue-300"
          data-i18n-key="pages.strategy.portfolioEyebrow"
        >
          {t('pages.strategy.portfolioEyebrow')}
        </p>
        <h2
          class="mt-3 text-3xl font-bold tracking-tight text-slate-950 dark:text-white md:text-5xl"
          data-i18n-key="pages.strategy.portfolioTitle"
        >
          {t('pages.strategy.portfolioTitle')}
        </h2>
      </div>
      <div class="mt-10 grid gap-5 lg:grid-cols-3">
        {
          solutions.map((solution) => {
            const key = solution.name.toLowerCase();

            return (
              <a
                href={getPermalink(solution.href)}
                class="block border border-slate-200 p-7 transition hover:-translate-y-1 hover:border-cyan-300 hover:bg-slate-50 dark:border-slate-800 dark:hover:border-cyan-500 dark:hover:bg-slate-900"
              >
                <Icon name={solution.icon} class="h-8 w-8 text-blue-700 dark:text-blue-300" />
                <p
                  class="mt-6 text-sm font-semibold uppercase tracking-wide text-slate-500"
                  data-i18n-key={`data.solutions.${key}.domain`}
                >
                  {t(`data.solutions.${key}.domain`)}
                </p>
                <h3 class="mt-2 text-2xl font-bold text-slate-950 dark:text-white">{solution.name}</h3>
                <p
                  class="mt-4 leading-relaxed text-slate-600 dark:text-slate-300"
                  data-i18n-key={`data.solutions.${key}.summary`}
                >
                  {t(`data.solutions.${key}.summary`)}
                </p>
              </a>
            );
          })
        }
      </div>
    </div>
  </section>

  <section class="not-prose bg-slate-950 py-16 text-white md:py-24">
    <div class="mx-auto grid max-w-7xl gap-12 px-4 sm:px-6 lg:grid-cols-[0.8fr_1.2fr]">
      <div>
        <p
          class="text-sm font-bold uppercase tracking-wide text-blue-200"
          data-i18n-key="pages.strategy.extensionsEyebrow"
        >
          {t('pages.strategy.extensionsEyebrow')}
        </p>
        <h2 class="mt-3 text-3xl font-bold tracking-tight md:text-5xl" data-i18n-key="pages.strategy.extensionsTitle">
          {t('pages.strategy.extensionsTitle')}
        </h2>
        <p class="mt-5 leading-relaxed text-slate-300" data-i18n-key="pages.strategy.extensionsDescription">
          {t('pages.strategy.extensionsDescription')}
        </p>
      </div>
      <div class="grid gap-4 md:grid-cols-2">
        {
          collaborationSolutions.map((item, index) => {
            const key = collaborationKeys[index];

            return (
              <article class="border border-white/10 bg-white/[0.03] p-6">
                <p
                  class="text-sm font-semibold text-blue-200"
                  data-i18n-key={`data.collaborationSolutions.${key}.domain`}
                >
                  {t(`data.collaborationSolutions.${key}.domain`)}
                </p>
                <h3 class="mt-2 text-xl font-bold">{item.name}</h3>
                <p
                  class="mt-3 text-sm leading-relaxed text-slate-300"
                  data-i18n-key={`data.collaborationSolutions.${key}.description`}
                >
                  {t(`data.collaborationSolutions.${key}.description`)}
                </p>
              </article>
            );
          })
        }
      </div>
    </div>
  </section>
</Layout>
