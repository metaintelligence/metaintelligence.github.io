---
import { Icon } from 'astro-icon/components';

import Layout from '~/layouts/PageLayout.astro';
import { collaborationSolutions, solutions } from '~/data/site';
import { getPermalink } from '~/utils/permalinks';

import metainsightScreen from '~/assets/images/ida/ida_result_overview.png';
import mviEvidence from '~/assets/images/refs/mvi-defect-evidence.png';

const metadata = {
  title: 'Solutions',
  description:
    'MetaIntelligence solution portfolio across MetaInsight, MVI, DIANA, and selective collaboration extensions.',
};

const visuals: Partial<Record<string, typeof metainsightScreen>> = {
  MVI: mviEvidence,
  MetaInsight: metainsightScreen,
};

const publicNotes: Record<string, string[]> = {
  MVI: [
    'Normal-data-based anomaly detection for scarce defect-data environments.',
    'Targeted GenAI augmentation for product-state and defect examples.',
    '3-BIN review and human feedback loop for field-adaptive operation.',
  ],
  MetaInsight: [
    'Collection, cleansing, clustering, and signal scoring for configurable domain datasets.',
    'Evidence-linked screens for analyst review, not opaque report generation.',
    'Built from repeated public R&D analytics execution, then generalized as a domain signal engine.',
  ],
  DIANA: [
    'Agentic layer on top of structured domain data, documents, and source evidence.',
    'Designed for source-grounded intelligence units, reports, and review notes.',
    'Uses verification steps to reduce unsupported generation and numerical errors.',
  ],
};

const dianaDiagram = [
  ['Plan', 'Domain task breakdown'],
  ['Retrieve', 'Evidence and source IDs'],
  ['Check', 'Rules, metrics, and consistency'],
  ['Draft', 'Reviewable intelligence output'],
];

const verificationDiagram = [
  ['Structured Input', 'Records, documents, dates, groups, and source identifiers enter as evidence.'],
  ['Separated Reasoning', 'Scoring, calculation, retrieval, and generation remain distinct steps.'],
  ['Reviewable Output', 'Reports, briefs, and notes preserve evidence links and uncertainty markers.'],
];
---

<Layout metadata={metadata}>
  <section class="not-prose bg-white py-16 dark:bg-slate-950 md:py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6">
      <div class="max-w-4xl">
        <p class="text-sm font-bold uppercase tracking-wide text-cyan-700 dark:text-cyan-300">Solutions</p>
        <h1 class="mt-4 text-4xl font-bold tracking-tight text-slate-950 dark:text-white md:text-6xl">
          A focused portfolio for signal, vision, and source-grounded intelligence
        </h1>
        <p class="mt-6 text-lg leading-relaxed text-slate-600 dark:text-slate-300 md:text-xl">
          MetaIntelligence presents three public product lines and a small set of collaboration extensions. Each item
          below opens selectively for deeper context while keeping the page focused.
        </p>
      </div>
    </div>
  </section>

  <section class="not-prose bg-slate-50 py-16 dark:bg-slate-900 md:py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6">
      <div class="grid gap-6">
        {
          solutions.map((solution, index) => {
            const visual = visuals[solution.name];
            const notes = publicNotes[solution.name];

            return (
              <article class="grid overflow-hidden border border-slate-200 bg-white dark:border-slate-800 dark:bg-slate-950 lg:grid-cols-[0.92fr_1.08fr]">
                <div class:list={['p-7 md:p-9', index % 2 === 1 ? 'lg:order-2' : '']}>
                  <div class="flex h-12 w-12 items-center justify-center bg-slate-100 text-cyan-700 dark:bg-slate-900 dark:text-cyan-300">
                    <Icon name={solution.icon} class="h-7 w-7" />
                  </div>
                  <p class="mt-7 text-sm font-semibold uppercase tracking-wide text-slate-500 dark:text-slate-400">
                    {solution.domain}
                  </p>
                  <h2 class="mt-2 text-3xl font-bold text-slate-950 dark:text-white">{solution.name}</h2>
                  <p class="mt-2 text-sm font-medium text-cyan-700 dark:text-cyan-300">{solution.fullName}</p>
                  <p class="mt-5 text-lg leading-relaxed text-slate-600 dark:text-slate-300">{solution.summary}</p>

                  <details class="mt-6 scroll-mt-28 border border-slate-200 dark:border-slate-800">
                    <summary class="cursor-pointer px-5 py-4 text-sm font-bold text-slate-950 marker:text-cyan-700 dark:text-white">
                      Detailed scope
                    </summary>
                    <div class="border-t border-slate-200 px-5 py-5 dark:border-slate-800">
                      <ul class="space-y-3 text-sm leading-relaxed text-slate-600 dark:text-slate-300">
                        {notes.map((note) => (
                          <li class="flex gap-3">
                            <Icon
                              name="tabler:check"
                              class="mt-0.5 h-5 w-5 shrink-0 text-cyan-700 dark:text-cyan-300"
                            />
                            <span>{note}</span>
                          </li>
                        ))}
                      </ul>
                      <p class="mt-5 text-sm leading-relaxed text-slate-500 dark:text-slate-400">{solution.proof}</p>
                    </div>
                  </details>

                  <a
                    href={getPermalink(solution.href)}
                    class="mt-6 inline-flex items-center gap-2 bg-slate-950 px-5 py-3 text-sm font-semibold text-white transition hover:bg-slate-800 dark:bg-white dark:text-slate-950"
                  >
                    Open {solution.name}
                    <Icon name="tabler:arrow-right" class="h-4 w-4" />
                  </a>
                </div>
                <div class:list={['bg-slate-950 p-4', index % 2 === 1 ? 'lg:order-1' : '']}>
                  {visual ? (
                    <img
                      src={visual.src}
                      width={visual.width}
                      height={visual.height}
                      alt={`${solution.name} reference visual`}
                      class="h-full min-h-[320px] w-full object-contain object-center"
                      loading={index === 0 ? 'eager' : 'lazy'}
                    />
                  ) : (
                    <div class="grid h-full min-h-[320px] content-center gap-3">
                      <p class="text-xs font-bold uppercase tracking-[0.18em] text-cyan-200">DIANA Agent Flow</p>
                      {dianaDiagram.map(([title, description], stepIndex) => (
                        <article class="border border-white/10 bg-white/[0.04] p-4 text-white">
                          <p class="text-xs font-bold text-cyan-200">{String(stepIndex + 1).padStart(2, '0')}</p>
                          <h3 class="mt-2 font-bold">{title}</h3>
                          <p class="mt-1 text-sm leading-relaxed text-slate-300">{description}</p>
                        </article>
                      ))}
                    </div>
                  )}
                </div>
              </article>
            );
          })
        }
      </div>
    </div>
  </section>

  <section class="not-prose bg-white py-16 dark:bg-slate-950 md:py-24">
    <div class="mx-auto grid max-w-7xl gap-12 px-4 sm:px-6 lg:grid-cols-[0.8fr_1.2fr]">
      <div>
        <p class="text-sm font-bold uppercase tracking-wide text-cyan-700 dark:text-cyan-300">Common Method</p>
        <h2 class="mt-3 text-3xl font-bold tracking-tight text-slate-950 dark:text-white md:text-5xl">
          Source-grounded verification is the shared layer
        </h2>
        <p class="mt-5 text-lg leading-relaxed text-slate-600 dark:text-slate-300">
          The same principle appears in domain signal analytics, document workflows, and operating analytics: data
          enters as structured evidence, calculations are separated from generation, and outputs remain reviewable.
        </p>
      </div>
      <div class="grid gap-3">
        {
          verificationDiagram.map(([title, description], index) => (
            <article class="border border-slate-200 bg-slate-50 p-5 dark:border-slate-800 dark:bg-slate-900">
              <p class="text-xs font-bold uppercase tracking-wide text-cyan-700 dark:text-cyan-300">
                Layer {String(index + 1).padStart(2, '0')}
              </p>
              <h3 class="mt-3 text-lg font-bold text-slate-950 dark:text-white">{title}</h3>
              <p class="mt-2 text-sm leading-relaxed text-slate-600 dark:text-slate-300">{description}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="not-prose bg-slate-950 py-16 text-white md:py-24">
    <div class="mx-auto grid max-w-7xl gap-12 px-4 sm:px-6 lg:grid-cols-[0.78fr_1.22fr]">
      <div>
        <p class="text-sm font-bold uppercase tracking-wide text-cyan-200">Extensions</p>
        <h2 class="mt-3 text-3xl font-bold tracking-tight md:text-5xl">Selective collaboration directions</h2>
        <p class="mt-5 leading-relaxed text-slate-300">
          These are presented as applied directions and collaboration capabilities, separate from the three public
          product lines.
        </p>
      </div>
      <div class="grid gap-4 md:grid-cols-2">
        {
          collaborationSolutions.map((item) => (
            <article class="border border-white/10 bg-white/[0.03] p-6">
              <p class="text-sm font-semibold text-cyan-200">{item.domain}</p>
              <h3 class="mt-2 text-xl font-bold">{item.name}</h3>
              <p class="mt-3 text-sm leading-relaxed text-slate-300">{item.description}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>
</Layout>
