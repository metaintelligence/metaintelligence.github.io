---
import { Icon } from 'astro-icon/components';

import Layout from '~/layouts/PageLayout.astro';
import Logo from '~/components/Logo.astro';
import { capabilities, company, mainStats, principles, solutions, trackRecords } from '~/data/site';
import { getPermalink } from '~/utils/permalinks';

import inspectVideo from '~/assets/video/3_inspect.mp4';
import inspectPoster from '~/assets/images/mvi/mvi_inspect_thumbnail.png';
import overviewScreen from '~/assets/images/ida/ida_result_overview.png';

const metadata = {
  title: 'MetaIntelligence - Verification-driven AI',
  ignoreTitleTemplate: true,
  description:
    'MetaIntelligence builds verification-driven AI systems for manufacturing vision inspection, R&D intelligence, and agentic document analysis.',
};
---

<Layout metadata={metadata}>
  <section class="relative min-h-[calc(100vh-72px)] overflow-hidden bg-slate-950 text-white not-prose">
    <video
      class="absolute inset-0 h-full w-full object-cover opacity-42"
      src={inspectVideo}
      poster={inspectPoster.src}
      autoplay
      muted
      loop
      playsinline
      preload="metadata"
      aria-hidden="true"></video>
    <div
      class="absolute inset-0 bg-[linear-gradient(90deg,rgba(2,6,23,0.95)_0%,rgba(15,23,42,0.82)_52%,rgba(15,23,42,0.46)_100%)]"
    >
    </div>

    <div class="relative mx-auto flex min-h-[calc(100vh-72px)] max-w-7xl items-center px-4 py-20 sm:px-6 lg:py-24">
      <div class="max-w-4xl">
        <div class="mb-8 inline-flex items-center gap-3 border border-white/15 bg-white/5 px-4 py-2 backdrop-blur">
          <Logo mode="logo_only" size="h-8 w-8" />
          <span class="text-sm font-medium text-slate-200">MetaIntelligence Inc.</span>
        </div>

        <p class="text-sm font-semibold uppercase tracking-[0.18em] text-blue-200">First-Principle AI</p>
        <h1 class="mt-5 max-w-5xl text-4xl font-bold leading-tight tracking-tight sm:text-6xl lg:text-7xl">
          Verification-driven AI<br class="hidden md:block" />
          for manufacturing and R&D intelligence
        </h1>
        <p class="mt-7 max-w-3xl text-lg leading-relaxed text-slate-200 sm:text-xl">
          {company.shortDescription}
        </p>

        <div class="mt-9 flex flex-col gap-3 sm:flex-row">
          <a
            href={getPermalink('/solutions/mvi')}
            class="inline-flex items-center justify-center gap-2 bg-white px-5 py-3 text-sm font-semibold text-slate-950 transition hover:bg-blue-50"
          >
            View Solutions
            <Icon name="tabler:arrow-right" class="h-4 w-4" />
          </a>
          <a
            href={getPermalink('/tech/core-tech')}
            class="inline-flex items-center justify-center gap-2 border border-white/25 px-5 py-3 text-sm font-semibold text-white transition hover:bg-white/10"
          >
            Technology Capabilities
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="not-prose border-b border-slate-200 bg-white dark:border-slate-800 dark:bg-slate-950">
    <div class="mx-auto grid max-w-7xl gap-px px-4 py-8 sm:grid-cols-2 sm:px-6 lg:grid-cols-4">
      {
        mainStats.map((item) => (
          <div class="border-slate-200 py-5 sm:px-5 lg:border-l first:lg:border-l-0 dark:border-slate-800">
            <strong class="block text-3xl font-bold tracking-tight text-slate-950 dark:text-white">{item.value}</strong>
            <span class="mt-2 block text-sm leading-relaxed text-slate-600 dark:text-slate-300">{item.label}</span>
          </div>
        ))
      }
    </div>
  </section>

  <section class="not-prose bg-slate-50 py-16 dark:bg-slate-900 md:py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6">
      <div class="max-w-3xl">
        <p class="text-sm font-bold uppercase tracking-wide text-blue-700 dark:text-blue-300">Solutions</p>
        <h2 class="mt-3 text-3xl font-bold tracking-tight text-slate-950 dark:text-white md:text-5xl">
          Product lines built from one operating thesis
        </h2>
        <p class="mt-5 text-lg leading-relaxed text-slate-600 dark:text-slate-300">
          MetaIntelligence connects manufacturing vision AI, R&D data analytics, and agentic document intelligence
          through the same discipline: source-grounded outputs, measurable workflow value, and deployable software.
        </p>
      </div>

      <div class="mt-10 grid gap-5 lg:grid-cols-3">
        {
          solutions.map((solution) => (
            <a
              href={getPermalink(solution.href)}
              class="group flex min-h-[280px] flex-col border border-slate-200 bg-white p-7 transition hover:-translate-y-1 hover:border-blue-300 hover:shadow-xl hover:shadow-slate-200/70 dark:border-slate-800 dark:bg-slate-950 dark:hover:border-blue-500 dark:hover:shadow-none"
            >
              <div class="flex h-12 w-12 items-center justify-center bg-slate-100 text-blue-700 dark:bg-slate-900 dark:text-blue-300">
                <Icon name={solution.icon} class="h-7 w-7" />
              </div>
              <p class="mt-7 text-sm font-semibold uppercase tracking-wide text-slate-500 dark:text-slate-400">
                {solution.domain}
              </p>
              <h3 class="mt-2 text-2xl font-bold text-slate-950 dark:text-white">{solution.name}</h3>
              <p class="mt-3 grow leading-relaxed text-slate-600 dark:text-slate-300">{solution.summary}</p>
              <p class="mt-5 border-t border-slate-200 pt-4 text-sm leading-relaxed text-slate-500 dark:border-slate-800 dark:text-slate-400">
                {solution.proof}
              </p>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <section class="not-prose bg-white py-16 dark:bg-slate-950 md:py-24">
    <div class="mx-auto grid max-w-7xl gap-12 px-4 sm:px-6 lg:grid-cols-[0.9fr_1.1fr] lg:items-center">
      <div>
        <p class="text-sm font-bold uppercase tracking-wide text-blue-700 dark:text-blue-300">MetaInsight Preview</p>
        <h2 class="mt-3 text-3xl font-bold tracking-tight text-slate-950 dark:text-white md:text-5xl">
          From raw R&D records to evidence-linked insight
        </h2>
        <p class="mt-5 text-lg leading-relaxed text-slate-600 dark:text-slate-300">
          MetaInsight is shaped around the daily work of analysts: clean the dataset, organize technical signals,
          compare clusters, and generate reviewable outputs without losing the connection to source records.
        </p>
        <div class="mt-8 grid gap-3 sm:grid-cols-3">
          {
            ['Cleanse', 'Cluster', 'Report'].map((step, index) => (
              <div class="border border-slate-200 p-4 dark:border-slate-800">
                <span class="text-xs font-bold text-blue-700 dark:text-blue-300">0{index + 1}</span>
                <strong class="mt-2 block text-slate-950 dark:text-white">{step}</strong>
              </div>
            ))
          }
        </div>
      </div>
      <div
        class="overflow-hidden border border-slate-200 bg-slate-950 shadow-2xl shadow-slate-200 dark:border-slate-800 dark:shadow-none"
      >
        <img
          src={overviewScreen.src}
          width={overviewScreen.width}
          height={overviewScreen.height}
          alt="MetaInsight analytics overview screen"
          class="aspect-[16/10] w-full object-cover object-top"
          loading="lazy"
        />
      </div>
    </div>
  </section>

  <section class="not-prose bg-slate-950 py-16 text-white md:py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6">
      <div class="grid gap-12 lg:grid-cols-[0.8fr_1.2fr]">
        <div>
          <p class="text-sm font-bold uppercase tracking-wide text-blue-200">Technology Principles</p>
          <h2 class="mt-3 text-3xl font-bold tracking-tight md:text-5xl">Reliable systems before louder claims</h2>
          <p class="mt-5 text-lg leading-relaxed text-slate-300">
            The company presents technology through architecture, verification, and field readiness rather than broad AI
            slogans. Each product direction is evaluated as an operating system, not only a model demo.
          </p>
        </div>
        <div class="grid gap-4 md:grid-cols-3">
          {
            principles.map((item) => (
              <article class="border border-white/10 bg-white/[0.03] p-6">
                <Icon name={item.icon} class="h-8 w-8 text-blue-200" />
                <p class="mt-5 text-sm font-semibold uppercase tracking-wide text-slate-400">{item.title}</p>
                <h3 class="mt-2 text-xl font-bold">{item.label}</h3>
                <p class="mt-3 text-sm leading-relaxed text-slate-300">{item.description}</p>
              </article>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <section class="not-prose bg-white py-16 dark:bg-slate-950 md:py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6">
      <div class="max-w-3xl">
        <p class="text-sm font-bold uppercase tracking-wide text-blue-700 dark:text-blue-300">Capabilities</p>
        <h2 class="mt-3 text-3xl font-bold tracking-tight text-slate-950 dark:text-white md:text-5xl">
          Four capability pillars, one product architecture
        </h2>
      </div>
      <div class="mt-10 grid gap-5 md:grid-cols-2 lg:grid-cols-4">
        {
          capabilities.map((item) => (
            <article class="border border-slate-200 p-6 dark:border-slate-800">
              <Icon name={item.icon} class="h-8 w-8 text-blue-700 dark:text-blue-300" />
              <h3 class="mt-5 text-xl font-bold text-slate-950 dark:text-white">{item.title}</h3>
              <p class="mt-2 text-sm font-medium text-slate-500 dark:text-slate-400">{item.subtitle}</p>
              <p class="mt-4 text-sm leading-relaxed text-slate-600 dark:text-slate-300">{item.description}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="not-prose bg-slate-50 py-16 dark:bg-slate-900 md:py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6">
      <div class="grid gap-12 lg:grid-cols-[0.8fr_1.2fr]">
        <div>
          <p class="text-sm font-bold uppercase tracking-wide text-blue-700 dark:text-blue-300">Evidence</p>
          <h2 class="mt-3 text-3xl font-bold tracking-tight text-slate-950 dark:text-white md:text-5xl">
            A track record grounded in repeated execution
          </h2>
          <p class="mt-5 text-lg leading-relaxed text-slate-600 dark:text-slate-300">
            Public R&D analytics, registered IP, and applied manufacturing AI work form the base for the current product
            roadmap.
          </p>
        </div>
        <div class="space-y-4">
          {
            trackRecords.slice(0, 4).map((item) => (
              <article class="grid gap-4 border border-slate-200 bg-white p-5 dark:border-slate-800 dark:bg-slate-950 sm:grid-cols-[120px_1fr]">
                <div class="font-bold text-blue-700 dark:text-blue-300">{item.year}</div>
                <div>
                  <h3 class="font-bold text-slate-950 dark:text-white">{item.title}</h3>
                  <p class="mt-2 text-sm leading-relaxed text-slate-600 dark:text-slate-300">{item.description}</p>
                </div>
              </article>
            ))
          }
        </div>
      </div>
    </div>
  </section>
</Layout>
