---
import { Icon } from 'astro-icon/components';

import Layout from '~/layouts/PageLayout.astro';
import { company, trackRecords } from '~/data/site';
import { createTranslator } from '~/utils/i18n';

const t = createTranslator();

const metadata = {
  title: t('pages.missionHistory.metaTitle'),
  description: t('pages.missionHistory.metaDescription'),
};

const milestones = [
  {
    date: '2021.12',
    title: 'Company founded',
    description: `${company.formerName} was founded with a focus on computational science, AI, and data analytics.`,
  },
  {
    date: '2022.10',
    title: 'Public R&D analytics work begins',
    description:
      'The team entered R&D intelligence through funded research on global R&D project data and data science methods.',
  },
  {
    date: '2023.08',
    title: 'Registered patent secured',
    description: 'Patent KR 10-2573563 was registered for a natural data analysis system and method.',
  },
  {
    date: '2024.07',
    title: 'MetaInsight prototype',
    description:
      'R&D collection, cleansing, analytics, and report-generation workflows were expanded into a web-based prototype.',
  },
  {
    date: '2025.11',
    title: 'Company name changed to MetaIntelligence',
    description: 'The company repositioned around enterprise AI products from its base in Daegu Suseong Alpha City.',
  },
  {
    date: '2026',
    title: 'Manufacturing and agentic AI expansion',
    description:
      'Product directions are expanding around MVI, MetaInsight MFG, DIANA, and applied AI workflows for industry.',
  },
];

const milestoneKeys = ['founded', 'analytics', 'patent', 'prototype', 'rename', 'expansion'];
const trackRecordKeys = ['rnd', 'patent', 'prototype', 'vision', 'expansion'];
---

<Layout metadata={metadata}>
  <section class="not-prose bg-white py-16 dark:bg-slate-950 md:py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6">
      <div class="max-w-4xl">
        <p
          class="text-sm font-bold uppercase tracking-wide text-blue-700 dark:text-blue-300"
          data-i18n-key="pages.missionHistory.eyebrow"
        >
          {t('pages.missionHistory.eyebrow')}
        </p>
        <h1
          class="mt-4 text-4xl font-bold tracking-tight text-slate-950 dark:text-white md:text-6xl"
          data-i18n-key="pages.missionHistory.title"
        >
          {t('pages.missionHistory.title')}
        </h1>
        <p
          class="mt-6 text-lg leading-relaxed text-slate-600 dark:text-slate-300 md:text-xl"
          data-i18n-key="pages.missionHistory.description"
        >
          {t('pages.missionHistory.description')}
        </p>
      </div>
    </div>
  </section>

  <section class="not-prose bg-slate-50 py-16 dark:bg-slate-900 md:py-24">
    <div class="mx-auto max-w-5xl px-4 sm:px-6">
      <div class="relative border-l border-slate-300 pl-6 dark:border-slate-700 md:pl-10">
        {
          milestones.map((item, index) => {
            const key = milestoneKeys[index];

            return (
              <article class="relative mb-10 last:mb-0">
                <div class="absolute -left-[31px] top-1 flex h-10 w-10 items-center justify-center border border-slate-300 bg-white dark:border-slate-700 dark:bg-slate-950 md:-left-[61px]">
                  <Icon name="tabler:point-filled" class="h-4 w-4 text-blue-700 dark:text-blue-300" />
                </div>
                <div class="grid gap-3 md:grid-cols-[140px_1fr]">
                  <div class="font-bold text-blue-700 dark:text-blue-300">{item.date}</div>
                  <div>
                    <h2
                      class="text-2xl font-bold text-slate-950 dark:text-white"
                      data-i18n-key={`pages.missionHistory.milestones.${key}.title`}
                    >
                      {t(`pages.missionHistory.milestones.${key}.title`)}
                    </h2>
                    <p
                      class="mt-3 leading-relaxed text-slate-600 dark:text-slate-300"
                      data-i18n-key={`pages.missionHistory.milestones.${key}.description`}
                    >
                      {t(`pages.missionHistory.milestones.${key}.description`)}
                    </p>
                  </div>
                </div>
              </article>
            );
          })
        }
      </div>
    </div>
  </section>

  <section class="not-prose bg-white py-16 dark:bg-slate-950 md:py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6">
      <div class="max-w-3xl">
        <p
          class="text-sm font-bold uppercase tracking-wide text-blue-700 dark:text-blue-300"
          data-i18n-key="pages.missionHistory.evidenceEyebrow"
        >
          {t('pages.missionHistory.evidenceEyebrow')}
        </p>
        <h2
          class="mt-3 text-3xl font-bold tracking-tight text-slate-950 dark:text-white md:text-5xl"
          data-i18n-key="pages.missionHistory.evidenceTitle"
        >
          {t('pages.missionHistory.evidenceTitle')}
        </h2>
      </div>
      <div class="mt-10 grid gap-5 md:grid-cols-2">
        {
          trackRecords.map((item, index) => {
            const key = trackRecordKeys[index];

            return (
              <article class="border border-slate-200 p-6 dark:border-slate-800">
                <p class="text-sm font-bold text-blue-700 dark:text-blue-300">{item.year}</p>
                <h3
                  class="mt-2 text-xl font-bold text-slate-950 dark:text-white"
                  data-i18n-key={`data.trackRecords.${key}.title`}
                >
                  {t(`data.trackRecords.${key}.title`)}
                </h3>
                <p
                  class="mt-3 leading-relaxed text-slate-600 dark:text-slate-300"
                  data-i18n-key={`data.trackRecords.${key}.description`}
                >
                  {t(`data.trackRecords.${key}.description`)}
                </p>
              </article>
            );
          })
        }
      </div>
    </div>
  </section>
</Layout>
