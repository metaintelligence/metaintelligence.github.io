---
import { Icon } from 'astro-icon/components';

import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'Operating Principles',
  description: 'How MetaIntelligence works as a focused AI engineering team.',
};

const operatingPrinciples = [
  {
    title: 'Evidence before opinion',
    description:
      'Technical choices are judged by source data, reproducible outputs, and deployment constraints rather than preference or fashion.',
    icon: 'tabler:clipboard-check',
  },
  {
    title: 'Working software first',
    description:
      'Research results matter when they become usable systems. We keep prototypes close to product workflows and field operation.',
    icon: 'tabler:tool',
  },
  {
    title: 'Small team, clear ownership',
    description:
      'Responsibilities are kept explicit across research, data, product, and deployment so that decisions remain accountable.',
    icon: 'tabler:users-group',
  },
  {
    title: 'Respect for security and field limits',
    description:
      'Manufacturing and public-sector environments come with network, data, hardware, and review constraints. Product design starts there.',
    icon: 'tabler:lock-check',
  },
];
---

<Layout metadata={metadata}>
  <section class="not-prose bg-white py-16 dark:bg-slate-950 md:py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6">
      <div class="max-w-4xl">
        <p class="text-sm font-bold uppercase tracking-wide text-blue-700 dark:text-blue-300">Operating Principles</p>
        <h1 class="mt-4 text-4xl font-bold tracking-tight text-slate-950 dark:text-white md:text-6xl">
          A focused engineering culture for verifiable AI
        </h1>
        <p class="mt-6 text-lg leading-relaxed text-slate-600 dark:text-slate-300 md:text-xl">
          MetaIntelligence presents culture through how the team works: evidence-based decisions, working software,
          clear ownership, and respect for real operating constraints.
        </p>
      </div>
    </div>
  </section>

  <section class="not-prose bg-slate-50 py-16 dark:bg-slate-900 md:py-24">
    <div class="mx-auto grid max-w-7xl gap-5 px-4 sm:px-6 md:grid-cols-2">
      {
        operatingPrinciples.map((item) => (
          <article class="border border-slate-200 bg-white p-7 dark:border-slate-800 dark:bg-slate-950">
            <Icon name={item.icon} class="h-9 w-9 text-blue-700 dark:text-blue-300" />
            <h2 class="mt-6 text-2xl font-bold text-slate-950 dark:text-white">{item.title}</h2>
            <p class="mt-4 leading-relaxed text-slate-600 dark:text-slate-300">{item.description}</p>
          </article>
        ))
      }
    </div>
  </section>

  <section class="not-prose bg-white py-16 dark:bg-slate-950 md:py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6">
      <div class="border border-slate-200 p-8 dark:border-slate-800 md:p-10">
        <p class="text-sm font-bold uppercase tracking-wide text-blue-700 dark:text-blue-300">Engineering Standard</p>
        <h2 class="mt-3 text-3xl font-bold tracking-tight text-slate-950 dark:text-white">
          We prove value through operating systems, not presentation layers alone
        </h2>
        <p class="mt-4 max-w-4xl leading-relaxed text-slate-600 dark:text-slate-300">
          In R&D analytics, this means preserving the path from source records to final insight. In manufacturing vision
          AI, it means connecting models to feedback, retraining, and field decision procedures.
        </p>
      </div>
    </div>
  </section>
</Layout>
