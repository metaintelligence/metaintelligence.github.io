---
import Layout from '~/layouts/PageLayout.astro';
import { company } from '~/data/site';
import { getPermalink } from '~/utils/permalinks';

const metadata = {
  title: 'Company Introduction',
  description: 'A concise introduction to MetaIntelligence Inc.',
};
---

<Layout metadata={metadata}>
  <section class="not-prose bg-white py-16 dark:bg-slate-950 md:py-24">
    <div class="mx-auto max-w-4xl px-4 sm:px-6">
      <p class="text-sm font-bold uppercase tracking-wide text-blue-700 dark:text-blue-300">Company Introduction</p>
      <h1 class="mt-4 text-4xl font-bold tracking-tight text-slate-950 dark:text-white md:text-6xl">
        {company.legalNameEn}
      </h1>
      <p class="mt-6 text-lg leading-relaxed text-slate-600 dark:text-slate-300 md:text-xl">
        {company.shortDescription}
      </p>
      <div class="mt-8">
        <a
          href={getPermalink('/company/identity')}
          class="font-semibold text-blue-700 hover:underline dark:text-blue-300"
        >
          Continue to Company Identity
        </a>
      </div>
    </div>
  </section>
</Layout>
