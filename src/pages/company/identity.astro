---
import { Icon } from 'astro-icon/components';

import Layout from '~/layouts/PageLayout.astro';
import { capabilities, mainStats, principles } from '~/data/site';
import { createTranslator } from '~/utils/i18n';
import { getPermalink } from '~/utils/permalinks';

const t = createTranslator();

const metadata = {
  title: t('pages.companyIdentity.metaTitle'),
  description: t('pages.companyIdentity.metaDescription'),
};

const mainStatKeys = ['founded', 'execution', 'records', 'patent'];
const principleKeys = ['first', 'verification', 'open'];
const capabilityKeys = ['multimodal', 'knowledge', 'hpc', 'signal'];
---

<Layout metadata={metadata}>
  <section class="not-prose bg-white py-16 dark:bg-slate-950 md:py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6">
      <div class="max-w-4xl">
        <p
          class="text-sm font-bold uppercase tracking-wide text-blue-700 dark:text-blue-300"
          data-i18n-key="pages.companyIdentity.eyebrow"
        >
          {t('pages.companyIdentity.eyebrow')}
        </p>
        <h1
          class="mt-4 text-4xl font-bold tracking-tight text-slate-950 dark:text-white md:text-6xl"
          data-i18n-key="pages.companyIdentity.title"
        >
          {t('pages.companyIdentity.title')}
        </h1>
        <p
          class="mt-6 text-lg leading-relaxed text-slate-600 dark:text-slate-300 md:text-xl"
          data-i18n-key="pages.companyIdentity.description"
        >
          {t('pages.companyIdentity.description')}
        </p>
      </div>

      <div
        class="mt-10 grid gap-px overflow-hidden border border-slate-200 bg-slate-200 dark:border-slate-800 dark:bg-slate-800 sm:grid-cols-2 lg:grid-cols-4"
      >
        {
          mainStats.map((item, index) => (
            <div class="bg-white p-6 dark:bg-slate-950">
              <strong class="block text-3xl font-bold text-slate-950 dark:text-white">{item.value}</strong>
              <span
                class="mt-2 block text-sm leading-relaxed text-slate-600 dark:text-slate-300"
                data-i18n-key={`data.mainStats.${mainStatKeys[index]}`}
              >
                {t(`data.mainStats.${mainStatKeys[index]}`)}
              </span>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section class="not-prose bg-slate-50 py-16 dark:bg-slate-900 md:py-24">
    <div class="mx-auto grid max-w-7xl gap-12 px-4 sm:px-6 lg:grid-cols-[0.75fr_1.25fr]">
      <div>
        <p
          class="text-sm font-bold uppercase tracking-wide text-blue-700 dark:text-blue-300"
          data-i18n-key="pages.companyIdentity.missionEyebrow"
        >
          {t('pages.companyIdentity.missionEyebrow')}
        </p>
        <h2
          class="mt-3 text-3xl font-bold tracking-tight text-slate-950 dark:text-white md:text-5xl"
          data-i18n-key="pages.companyIdentity.missionTitle"
        >
          {t('pages.companyIdentity.missionTitle')}
        </h2>
        <p
          class="mt-5 text-lg leading-relaxed text-slate-600 dark:text-slate-300"
          data-i18n-key="pages.companyIdentity.missionDescription"
        >
          {t('pages.companyIdentity.missionDescription')}
        </p>
      </div>
      <div class="grid gap-5 md:grid-cols-3">
        {
          principles.map((item, index) => {
            const key = principleKeys[index];

            return (
              <article class="border border-slate-200 bg-white p-6 dark:border-slate-800 dark:bg-slate-950">
                <Icon name={item.icon} class="h-8 w-8 text-blue-700 dark:text-blue-300" />
                <p
                  class="mt-5 text-sm font-semibold uppercase tracking-wide text-slate-500"
                  data-i18n-key={`data.principles.${key}.title`}
                >
                  {t(`data.principles.${key}.title`)}
                </p>
                <h3
                  class="mt-2 text-xl font-bold text-slate-950 dark:text-white"
                  data-i18n-key={`data.principles.${key}.label`}
                >
                  {t(`data.principles.${key}.label`)}
                </h3>
                <p
                  class="mt-3 text-sm leading-relaxed text-slate-600 dark:text-slate-300"
                  data-i18n-key={`data.principles.${key}.description`}
                >
                  {t(`data.principles.${key}.description`)}
                </p>
              </article>
            );
          })
        }
      </div>
    </div>
  </section>

  <section class="not-prose bg-white py-16 dark:bg-slate-950 md:py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6">
      <div class="max-w-3xl">
        <p
          class="text-sm font-bold uppercase tracking-wide text-blue-700 dark:text-blue-300"
          data-i18n-key="pages.companyIdentity.competenciesEyebrow"
        >
          {t('pages.companyIdentity.competenciesEyebrow')}
        </p>
        <h2
          class="mt-3 text-3xl font-bold tracking-tight text-slate-950 dark:text-white md:text-5xl"
          data-i18n-key="pages.companyIdentity.competenciesTitle"
        >
          {t('pages.companyIdentity.competenciesTitle')}
        </h2>
      </div>
      <div class="mt-10 grid gap-5 md:grid-cols-2">
        {
          capabilities.map((item, index) => {
            const key = capabilityKeys[index];

            return (
              <article class="flex gap-5 border border-slate-200 p-6 dark:border-slate-800">
                <div class="flex h-12 w-12 shrink-0 items-center justify-center bg-slate-100 text-blue-700 dark:bg-slate-900 dark:text-blue-300">
                  <Icon name={item.icon} class="h-7 w-7" />
                </div>
                <div>
                  <h3
                    class="text-xl font-bold text-slate-950 dark:text-white"
                    data-i18n-key={`data.capabilities.${key}.title`}
                  >
                    {t(`data.capabilities.${key}.title`)}
                  </h3>
                  <p
                    class="mt-1 text-sm font-medium text-slate-500 dark:text-slate-400"
                    data-i18n-key={`data.capabilities.${key}.subtitle`}
                  >
                    {t(`data.capabilities.${key}.subtitle`)}
                  </p>
                  <p
                    class="mt-3 leading-relaxed text-slate-600 dark:text-slate-300"
                    data-i18n-key={`data.capabilities.${key}.description`}
                  >
                    {t(`data.capabilities.${key}.description`)}
                  </p>
                </div>
              </article>
            );
          })
        }
      </div>
    </div>
  </section>

  <section class="not-prose bg-slate-950 py-16 text-white md:py-20">
    <div class="mx-auto flex max-w-7xl flex-col gap-6 px-4 sm:px-6 md:flex-row md:items-center md:justify-between">
      <div class="max-w-3xl">
        <p
          class="text-sm font-bold uppercase tracking-wide text-blue-200"
          data-i18n-key="pages.companyIdentity.nextEyebrow"
        >
          {t('pages.companyIdentity.nextEyebrow')}
        </p>
        <h2 class="mt-2 text-3xl font-bold tracking-tight" data-i18n-key="pages.companyIdentity.nextTitle">
          {t('pages.companyIdentity.nextTitle')}
        </h2>
        <p class="mt-3 text-slate-300" data-i18n-key="pages.companyIdentity.nextDescription">
          {t('pages.companyIdentity.nextDescription')}
        </p>
      </div>
      <a
        href={getPermalink('/company/mission-history')}
        class="inline-flex items-center justify-center gap-2 bg-white px-5 py-3 text-sm font-semibold text-slate-950 hover:bg-blue-50"
      >
        <span data-i18n-key="pages.companyIdentity.nextCta">{t('pages.companyIdentity.nextCta')}</span>
        <Icon name="tabler:arrow-right" class="h-4 w-4" />
      </a>
    </div>
  </section>
</Layout>
