---
import { Icon } from 'astro-icon/components';

import Layout from '~/layouts/PageLayout.astro';
import { trackRecords } from '~/data/site';
import { createTranslator } from '~/utils/i18n';

const t = createTranslator();

const metadata = {
  title: t('pages.trackRecord.metaTitle'),
  description: t('pages.trackRecord.metaDescription'),
};

const statValues = ['4 years', '9.96M+', 'KR 10-2573563', '2026'];
const governmentYears = ['2022', '2023', '2024', '2025'];
const collaborationTitles = ['MicroDIPS', 'MVI manufacturing PoC', 'MetaInsight MFG', 'AeroGimbal-Track'];
const statKeys = ['years', 'records', 'patent', 'roadmap'];
const governmentKeys = ['db', 'future', 'global', 'construction'];
const collaborationKeys = ['microdips', 'mvi', 'mfg', 'aero'];
const trackRecordKeys = ['rnd', 'patent', 'prototype', 'vision', 'expansion'];
---

<Layout metadata={metadata}>
  <section class="not-prose bg-white py-16 dark:bg-slate-950 md:py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6">
      <div class="max-w-4xl">
        <p
          class="text-sm font-bold uppercase tracking-wide text-blue-700 dark:text-blue-300"
          data-i18n-key="pages.trackRecord.eyebrow"
        >
          {t('pages.trackRecord.eyebrow')}
        </p>
        <h1
          class="mt-4 text-4xl font-bold tracking-tight text-slate-950 dark:text-white md:text-6xl"
          data-i18n-key="pages.trackRecord.title"
        >
          {t('pages.trackRecord.title')}
        </h1>
        <p
          class="mt-6 text-lg leading-relaxed text-slate-600 dark:text-slate-300 md:text-xl"
          data-i18n-key="pages.trackRecord.description"
        >
          {t('pages.trackRecord.description')}
        </p>
      </div>
    </div>
  </section>

  <section class="not-prose bg-slate-50 py-16 dark:bg-slate-900 md:py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6">
      <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
        {
          statValues.map((value, index) => (
            <div class="border border-slate-200 bg-white p-6 dark:border-slate-800 dark:bg-slate-950">
              <strong class="block text-3xl font-bold text-slate-950 dark:text-white">{value}</strong>
              <span
                class="mt-2 block text-sm text-slate-600 dark:text-slate-300"
                data-i18n-key={`pages.trackRecord.stats.${statKeys[index]}`}
              >
                {t(`pages.trackRecord.stats.${statKeys[index]}`)}
              </span>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section class="not-prose bg-white py-16 dark:bg-slate-950 md:py-24">
    <div class="mx-auto grid max-w-7xl gap-12 px-4 sm:px-6 lg:grid-cols-[0.75fr_1.25fr]">
      <div>
        <p
          class="text-sm font-bold uppercase tracking-wide text-blue-700 dark:text-blue-300"
          data-i18n-key="pages.trackRecord.governmentEyebrow"
        >
          {t('pages.trackRecord.governmentEyebrow')}
        </p>
        <h2
          class="mt-3 text-3xl font-bold tracking-tight text-slate-950 dark:text-white md:text-5xl"
          data-i18n-key="pages.trackRecord.governmentTitle"
        >
          {t('pages.trackRecord.governmentTitle')}
        </h2>
      </div>
      <div class="space-y-4">
        {
          governmentYears.map((year, index) => {
            const key = governmentKeys[index];

            return (
              <article class="grid gap-4 border border-slate-200 p-5 dark:border-slate-800 sm:grid-cols-[90px_1fr]">
                <div class="font-bold text-blue-700 dark:text-blue-300">{year}</div>
                <div>
                  <h3
                    class="font-bold text-slate-950 dark:text-white"
                    data-i18n-key={`pages.trackRecord.government.${key}.title`}
                  >
                    {t(`pages.trackRecord.government.${key}.title`)}
                  </h3>
                  <p
                    class="mt-2 text-sm leading-relaxed text-slate-600 dark:text-slate-300"
                    data-i18n-key={`pages.trackRecord.government.${key}.description`}
                  >
                    {t(`pages.trackRecord.government.${key}.description`)}
                  </p>
                </div>
              </article>
            );
          })
        }
      </div>
    </div>
  </section>

  <section class="not-prose bg-slate-950 py-16 text-white md:py-24">
    <div class="mx-auto grid max-w-7xl gap-12 px-4 sm:px-6 lg:grid-cols-[0.75fr_1.25fr]">
      <div>
        <p
          class="text-sm font-bold uppercase tracking-wide text-blue-200"
          data-i18n-key="pages.trackRecord.extensionsEyebrow"
        >
          {t('pages.trackRecord.extensionsEyebrow')}
        </p>
        <h2
          class="mt-3 text-3xl font-bold tracking-tight md:text-5xl"
          data-i18n-key="pages.trackRecord.extensionsTitle"
        >
          {t('pages.trackRecord.extensionsTitle')}
        </h2>
      </div>
      <div class="grid gap-4 md:grid-cols-2">
        {
          collaborationTitles.map((title, index) => (
            <article class="border border-white/10 bg-white/[0.03] p-6">
              <Icon name="tabler:briefcase" class="h-6 w-6 text-blue-200" />
              <h3 class="mt-5 text-xl font-bold">{title}</h3>
              <p
                class="mt-3 text-sm leading-relaxed text-slate-300"
                data-i18n-key={`pages.trackRecord.collaboration.${collaborationKeys[index]}`}
              >
                {t(`pages.trackRecord.collaboration.${collaborationKeys[index]}`)}
              </p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="not-prose bg-white py-16 dark:bg-slate-950 md:py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6">
      <div class="space-y-4">
        {
          trackRecords.map((item, index) => {
            const key = trackRecordKeys[index];

            return (
              <div class="grid gap-4 border border-slate-200 p-5 dark:border-slate-800 md:grid-cols-[130px_1fr]">
                <div class="font-bold text-blue-700 dark:text-blue-300">{item.year}</div>
                <div>
                  <h3 class="font-bold text-slate-950 dark:text-white" data-i18n-key={`data.trackRecords.${key}.title`}>
                    {t(`data.trackRecords.${key}.title`)}
                  </h3>
                  <p
                    class="mt-2 text-sm leading-relaxed text-slate-600 dark:text-slate-300"
                    data-i18n-key={`data.trackRecords.${key}.description`}
                  >
                    {t(`data.trackRecords.${key}.description`)}
                  </p>
                </div>
              </div>
            );
          })
        }
      </div>
    </div>
  </section>
</Layout>
