---
import Layout from '~/layouts/PageLayout.astro';
import { company } from '~/data/site';
import { createTranslator } from '~/utils/i18n';

const t = createTranslator();

const metadata = {
  title: t('pages.privacy.metaTitle'),
};
---

<Layout metadata={metadata}>
  <section class="not-prose bg-white py-16 dark:bg-slate-950 md:py-24">
    <div class="mx-auto max-w-4xl px-4 sm:px-6">
      <p
        class="text-sm font-bold uppercase tracking-wide text-blue-700 dark:text-blue-300"
        data-i18n-key="pages.privacy.updated"
      >
        {t('pages.privacy.updated')}
      </p>
      <h1
        class="mt-4 text-4xl font-bold tracking-tight text-slate-950 dark:text-white md:text-5xl"
        data-i18n-key="pages.privacy.metaTitle"
      >
        {t('pages.privacy.metaTitle')}
      </h1>
      <p class="mt-6 text-lg leading-relaxed text-slate-600 dark:text-slate-300" data-i18n-key="pages.privacy.intro">
        {t('pages.privacy.intro')}
      </p>

      <div class="mt-10 space-y-8 text-slate-600 dark:text-slate-300">
        <section>
          <h2 class="text-2xl font-bold text-slate-950 dark:text-white" data-i18n-key="pages.privacy.collectTitle">
            {t('pages.privacy.collectTitle')}
          </h2>
          <p class="mt-3 leading-relaxed" data-i18n-key="pages.privacy.collect1">{t('pages.privacy.collect1')}</p>
          <p class="mt-3 leading-relaxed" data-i18n-key="pages.privacy.collect2">{t('pages.privacy.collect2')}</p>
        </section>
        <section>
          <h2 class="text-2xl font-bold text-slate-950 dark:text-white" data-i18n-key="pages.privacy.sensitiveTitle">
            {t('pages.privacy.sensitiveTitle')}
          </h2>
          <p class="mt-3 leading-relaxed" data-i18n-key="pages.privacy.sensitive">{t('pages.privacy.sensitive')}</p>
        </section>
        <section>
          <h2 class="text-2xl font-bold text-slate-950 dark:text-white" data-i18n-key="pages.privacy.useTitle">
            {t('pages.privacy.useTitle')}
          </h2>
          <p class="mt-3 leading-relaxed" data-i18n-key="pages.privacy.use">{t('pages.privacy.use')}</p>
        </section>
        <section>
          <h2 class="text-2xl font-bold text-slate-950 dark:text-white" data-i18n-key="pages.privacy.retentionTitle">
            {t('pages.privacy.retentionTitle')}
          </h2>
          <p class="mt-3 leading-relaxed" data-i18n-key="pages.privacy.retention">{t('pages.privacy.retention')}</p>
        </section>
        <section>
          <h2 class="text-2xl font-bold text-slate-950 dark:text-white" data-i18n-key="pages.privacy.thirdPartyTitle">
            {t('pages.privacy.thirdPartyTitle')}
          </h2>
          <p class="mt-3 leading-relaxed" data-i18n-key="pages.privacy.thirdParty">{t('pages.privacy.thirdParty')}</p>
        </section>
        <section>
          <h2 class="text-2xl font-bold text-slate-950 dark:text-white" data-i18n-key="pages.privacy.contactTitle">
            {t('pages.privacy.contactTitle')}
          </h2>
          <p class="mt-3 leading-relaxed" data-i18n-key="pages.privacy.contact">{t('pages.privacy.contact')}</p>
          <ul class="mt-3 space-y-1">
            <li>
              <span data-i18n-key="pages.contact.labels.email">{t('pages.contact.labels.email')}</span>:
              <a class="text-blue-700 hover:underline dark:text-blue-300" href={`mailto:${company.email}`}
                >{company.email}</a
              >
            </li>
            <li>
              <span data-i18n-key="pages.contact.labels.phone">{t('pages.contact.labels.phone')}</span>:
              <a class="text-blue-700 hover:underline dark:text-blue-300" href="tel:+82537194290">{company.phone}</a>
            </li>
          </ul>
        </section>
      </div>
    </div>
  </section>
</Layout>
