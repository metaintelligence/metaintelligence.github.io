---
import Layout from '~/layouts/PageLayout.astro';

import Hero2 from '~/components/widgets/Hero2.astro';
import BlogLatestPosts from '~/components/widgets/BlogLatestPosts.astro';

const metadata = {
  title: 'Case Studies — MetaIntelligence',
  description: '실제 산업 현장에서 검증된 MetaIntelligence의 도입 사례와 성과를 확인하세요.',
};
---

<Layout metadata={metadata}>
  <Hero2
    tagline="Insights"
    image={{
      src: 'https://images.unsplash.com/photo-1581090700227-1e8e8d7ed5be?auto=format&fit=crop&w=2070&q=80',
      alt: 'Case Studies',
    }}
  >
    <Fragment slot="title">Case Studies</Fragment>
    <Fragment slot="subtitle">
      제조, 물류, 공공 등 다양한 산업 현장에서 MetaIntelligence가 어떻게 본질적인 문제를 해결했는지, 도입 전후의
      구체적인 성과 지표와 함께 소개합니다.
    </Fragment>
  </Hero2>

  <BlogLatestPosts
    title="고객 성공 사례"
    information="현장의 문제, 우리가 설계한 해법, 도입 이후의 변화를 한 편의 이야기로 전합니다."
    category="case-studies"
    count={6}
    emptyMessage="현재 공개 가능한 사례를 정리하고 있습니다. 비공개 도입 사례 자료가 필요하시면 문의해 주세요."
  />

</Layout>
