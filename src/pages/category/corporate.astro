---
import Layout from '~/layouts/PageLayout.astro';

import Hero2 from '~/components/widgets/Hero2.astro';
import BlogLatestPosts from '~/components/widgets/BlogLatestPosts.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'Corporate News — MetaIntelligence',
  description: 'MetaIntelligence의 공식 발표, 투자, 파트너십 등 기업 소식을 전합니다.',
};
---

<Layout metadata={metadata}>
  <Hero2
    tagline="Insights"
    image={{
      src: 'https://images.unsplash.com/photo-1454165804606-c3d57bc86b40?auto=format&fit=crop&w=2070&q=80',
      alt: 'Corporate News',
    }}
  >
    <Fragment slot="title">Corporate News</Fragment>
    <Fragment slot="subtitle">
      MetaIntelligence의 공식 발표, 투자 유치, 파트너십, 신규 솔루션 출시 등 회사의 주요 행보를 가장 먼저 만나보세요.
    </Fragment>
  </Hero2>

  <BlogLatestPosts
    title="최근 소식"
    information="회사의 공식 발표와 주요 사건을 시간순으로 정리해 전달드립니다."
    category="corporate"
    count={6}
    emptyMessage="첫 번째 공식 소식을 곧 전해드리겠습니다. 조금만 기다려 주세요."
  />

  <CallToAction actions={[{ variant: 'primary', text: 'Contact Us', href: '/contact', icon: 'tabler:mail' }]}>
    <Fragment slot="title">함께할 미래를 제안합니다</Fragment>
    <Fragment slot="subtitle"> 파트너십, 투자, 미디어 문의는 언제든지 환영합니다. </Fragment>
  </CallToAction>
</Layout>
