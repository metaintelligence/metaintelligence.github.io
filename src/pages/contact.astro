---
import { Icon } from 'astro-icon/components';

import Layout from '~/layouts/PageLayout.astro';
import { company } from '~/data/site';
import { createTranslator } from '~/utils/i18n';

const t = createTranslator();

const metadata = {
  title: t('pages.contact.metaTitle'),
  description: t('pages.contact.metaDescription'),
};

const contacts = [
  { key: 'email', value: company.email, href: `mailto:${company.email}`, icon: 'tabler:mail' },
  { key: 'phone', value: company.phone, href: 'tel:+82537194290', icon: 'tabler:phone' },
  { key: 'fax', value: company.fax, href: null, icon: 'tabler:printer' },
  {
    key: 'headquarters',
    value: t('data.company.headquarters'),
    href: null,
    icon: 'tabler:map-pin',
    valueKey: 'data.company.headquarters',
  },
];

const inquiryScopes = [
  ['MVI', 'mvi'],
  ['MetaInsight', 'metainsight'],
  ['DIANA', 'diana'],
];
---

<Layout metadata={metadata}>
  <section class="not-prose bg-white py-16 dark:bg-slate-950 md:py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6">
      <div class="max-w-4xl">
        <p
          class="text-sm font-bold uppercase tracking-wide text-blue-700 dark:text-blue-300"
          data-i18n-key="pages.contact.eyebrow"
        >
          {t('pages.contact.eyebrow')}
        </p>
        <h1
          class="mt-4 text-4xl font-bold tracking-tight text-slate-950 dark:text-white md:text-6xl"
          data-i18n-key="pages.contact.title"
        >
          {t('pages.contact.title')}
        </h1>
        <p
          class="mt-6 text-lg leading-relaxed text-slate-600 dark:text-slate-300 md:text-xl"
          data-i18n-key="pages.contact.description"
        >
          {t('pages.contact.description')}
        </p>
      </div>
    </div>
  </section>

  <section class="not-prose bg-slate-50 py-16 dark:bg-slate-900 md:py-24">
    <div class="mx-auto grid max-w-7xl gap-5 px-4 sm:px-6 md:grid-cols-2">
      {
        contacts.map((item) => (
          <article class="border border-slate-200 bg-white p-7 dark:border-slate-800 dark:bg-slate-950">
            <Icon name={item.icon} class="h-8 w-8 text-blue-700 dark:text-blue-300" />
            <h2
              class="mt-5 text-xl font-bold text-slate-950 dark:text-white"
              data-i18n-key={`pages.contact.labels.${item.key}`}
            >
              {t(`pages.contact.labels.${item.key}`)}
            </h2>
            {item.href ? (
              <a
                class="mt-3 block break-words text-slate-600 hover:text-blue-700 dark:text-slate-300 dark:hover:text-blue-300"
                href={item.href}
              >
                {item.value}
              </a>
            ) : (
              <p
                class="mt-3 break-words leading-relaxed text-slate-600 dark:text-slate-300"
                data-i18n-key={item.valueKey}
              >
                {item.value}
              </p>
            )}
          </article>
        ))
      }
    </div>
  </section>

  <section class="not-prose bg-white py-16 dark:bg-slate-950 md:py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6">
      <div class="border border-slate-200 p-8 dark:border-slate-800 md:p-10">
        <p
          class="text-sm font-bold uppercase tracking-wide text-blue-700 dark:text-blue-300"
          data-i18n-key="pages.contact.scopeEyebrow"
        >
          {t('pages.contact.scopeEyebrow')}
        </p>
        <h2
          class="mt-3 text-3xl font-bold tracking-tight text-slate-950 dark:text-white"
          data-i18n-key="pages.contact.scopeTitle"
        >
          {t('pages.contact.scopeTitle')}
        </h2>
        <div class="mt-8 grid gap-4 md:grid-cols-3">
          {
            inquiryScopes.map(([title, key]) => (
              <div class="border border-slate-200 p-5 dark:border-slate-800">
                <h3 class="font-bold text-slate-950 dark:text-white">{title}</h3>
                <p
                  class="mt-2 text-sm leading-relaxed text-slate-600 dark:text-slate-300"
                  data-i18n-key={`pages.contact.scope.${key}`}
                >
                  {t(`pages.contact.scope.${key}`)}
                </p>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </section>
</Layout>
