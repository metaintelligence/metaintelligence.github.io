---
import { Icon } from 'astro-icon/components';

import Layout from '~/layouts/PageLayout.astro';
import { company } from '~/data/site';

const metadata = {
  title: 'Contact',
  description: 'Contact MetaIntelligence Inc. in Daegu, Republic of Korea.',
};

const contacts = [
  { title: 'Email', value: company.email, href: `mailto:${company.email}`, icon: 'tabler:mail' },
  { title: 'Phone', value: company.phone, href: 'tel:+82537194290', icon: 'tabler:phone' },
  { title: 'Fax', value: company.fax, href: null, icon: 'tabler:printer' },
  { title: 'Headquarters', value: company.headquarters, href: null, icon: 'tabler:map-pin' },
];
---

<Layout metadata={metadata}>
  <section class="not-prose bg-white py-16 dark:bg-slate-950 md:py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6">
      <div class="max-w-4xl">
        <p class="text-sm font-bold uppercase tracking-wide text-blue-700 dark:text-blue-300">Contact</p>
        <h1 class="mt-4 text-4xl font-bold tracking-tight text-slate-950 dark:text-white md:text-6xl">
          Project and collaboration inquiries
        </h1>
        <p class="mt-6 text-lg leading-relaxed text-slate-600 dark:text-slate-300 md:text-xl">
          Contact MetaIntelligence for manufacturing vision AI, R&D intelligence, and grounded document-analysis
          workflows. Please avoid sending resident registration numbers, home addresses, or other unnecessary sensitive
          personal data.
        </p>
      </div>
    </div>
  </section>

  <section class="not-prose bg-slate-50 py-16 dark:bg-slate-900 md:py-24">
    <div class="mx-auto grid max-w-7xl gap-5 px-4 sm:px-6 md:grid-cols-2">
      {
        contacts.map((item) => (
          <article class="border border-slate-200 bg-white p-7 dark:border-slate-800 dark:bg-slate-950">
            <Icon name={item.icon} class="h-8 w-8 text-blue-700 dark:text-blue-300" />
            <h2 class="mt-5 text-xl font-bold text-slate-950 dark:text-white">{item.title}</h2>
            {item.href ? (
              <a
                class="mt-3 block break-words text-slate-600 hover:text-blue-700 dark:text-slate-300 dark:hover:text-blue-300"
                href={item.href}
              >
                {item.value}
              </a>
            ) : (
              <p class="mt-3 break-words leading-relaxed text-slate-600 dark:text-slate-300">{item.value}</p>
            )}
          </article>
        ))
      }
    </div>
  </section>

  <section class="not-prose bg-white py-16 dark:bg-slate-950 md:py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6">
      <div class="border border-slate-200 p-8 dark:border-slate-800 md:p-10">
        <p class="text-sm font-bold uppercase tracking-wide text-blue-700 dark:text-blue-300">Inquiry Scope</p>
        <h2 class="mt-3 text-3xl font-bold tracking-tight text-slate-950 dark:text-white">
          Areas where the team can respond most effectively
        </h2>
        <div class="mt-8 grid gap-4 md:grid-cols-3">
          {
            [
              [
                'MVI',
                'Manufacturing defect detection, vision inspection workflows, data augmentation, and field deployment.',
              ],
              [
                'MetaInsight',
                'R&D data analytics, emerging technology discovery, clustering, and evidence-linked reporting.',
              ],
              ['DIANA', 'Agentic document intelligence, retrieval workflows, LLM evaluation, and report automation.'],
            ].map(([title, description]) => (
              <div class="border border-slate-200 p-5 dark:border-slate-800">
                <h3 class="font-bold text-slate-950 dark:text-white">{title}</h3>
                <p class="mt-2 text-sm leading-relaxed text-slate-600 dark:text-slate-300">{description}</p>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </section>
</Layout>
