---
import { Icon } from 'astro-icon/components';

import Layout from '~/layouts/PageLayout.astro';
import { principles } from '~/data/site';

const metadata = {
  title: 'Technology Philosophy',
  description: 'MetaIntelligence technology philosophy: first principles, verification, and open architecture.',
};

const safeguards = [
  'Maintain a clear connection between source data and generated outputs.',
  'Prefer reproducible calculations and code-based checks where possible.',
  'Use LLMs with retrieval, templates, evaluation, and review stages instead of free-form generation alone.',
  'Design deployment around real network, security, data, and hardware constraints.',
];
---

<Layout metadata={metadata}>
  <section class="not-prose bg-white py-16 dark:bg-slate-950 md:py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6">
      <div class="max-w-4xl">
        <p class="text-sm font-bold uppercase tracking-wide text-blue-700 dark:text-blue-300">Technology Philosophy</p>
        <h1 class="mt-4 text-4xl font-bold tracking-tight text-slate-950 dark:text-white md:text-6xl">
          Trust comes from architecture, not from claims
        </h1>
        <p class="mt-6 text-lg leading-relaxed text-slate-600 dark:text-slate-300 md:text-xl">
          MetaIntelligence decomposes problems from first principles, constrains generated outputs with evidence, and
          designs systems that can be deployed inside the customer environment.
        </p>
      </div>
    </div>
  </section>

  <section class="not-prose bg-slate-50 py-16 dark:bg-slate-900 md:py-24">
    <div class="mx-auto grid max-w-7xl gap-5 px-4 sm:px-6 md:grid-cols-3">
      {
        principles.map((item) => (
          <article class="border border-slate-200 bg-white p-7 dark:border-slate-800 dark:bg-slate-950">
            <Icon name={item.icon} class="h-9 w-9 text-blue-700 dark:text-blue-300" />
            <p class="mt-6 text-sm font-semibold uppercase tracking-wide text-slate-500 dark:text-slate-400">
              {item.title}
            </p>
            <h2 class="mt-2 text-2xl font-bold text-slate-950 dark:text-white">{item.label}</h2>
            <p class="mt-4 leading-relaxed text-slate-600 dark:text-slate-300">{item.description}</p>
          </article>
        ))
      }
    </div>
  </section>

  <section class="not-prose bg-white py-16 dark:bg-slate-950 md:py-24">
    <div class="mx-auto grid max-w-7xl gap-12 px-4 sm:px-6 lg:grid-cols-[0.8fr_1.2fr]">
      <div>
        <p class="text-sm font-bold uppercase tracking-wide text-blue-700 dark:text-blue-300">Guardrails</p>
        <h2 class="mt-3 text-3xl font-bold tracking-tight text-slate-950 dark:text-white md:text-5xl">
          Reliability is expressed as system behavior
        </h2>
      </div>
      <div class="space-y-3">
        {
          safeguards.map((item) => (
            <div class="flex gap-4 border border-slate-200 p-5 dark:border-slate-800">
              <Icon name="tabler:check" class="mt-1 h-5 w-5 shrink-0 text-blue-700 dark:text-blue-300" />
              <p class="leading-relaxed text-slate-600 dark:text-slate-300">{item}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>
</Layout>
