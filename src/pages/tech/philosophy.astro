---
import { Icon } from 'astro-icon/components';

import Layout from '~/layouts/PageLayout.astro';
import { principles } from '~/data/site';
import { createTranslator } from '~/utils/i18n';

const t = createTranslator();

const metadata = {
  title: t('pages.philosophy.metaTitle'),
  description: t('pages.philosophy.metaDescription'),
};

const principleKeys = ['first', 'verification', 'open'];
const safeguards = ['source', 'calculation', 'llm', 'deployment'];
---

<Layout metadata={metadata}>
  <section class="not-prose bg-white py-16 dark:bg-slate-950 md:py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6">
      <div class="max-w-4xl">
        <p
          class="text-sm font-bold uppercase tracking-wide text-blue-700 dark:text-blue-300"
          data-i18n-key="pages.philosophy.eyebrow"
        >
          {t('pages.philosophy.eyebrow')}
        </p>
        <h1
          class="mt-4 text-4xl font-bold tracking-tight text-slate-950 dark:text-white md:text-6xl"
          data-i18n-key="pages.philosophy.title"
        >
          {t('pages.philosophy.title')}
        </h1>
        <p
          class="mt-6 text-lg leading-relaxed text-slate-600 dark:text-slate-300 md:text-xl"
          data-i18n-key="pages.philosophy.description"
        >
          {t('pages.philosophy.description')}
        </p>
      </div>
    </div>
  </section>

  <section class="not-prose bg-slate-50 py-16 dark:bg-slate-900 md:py-24">
    <div class="mx-auto grid max-w-7xl gap-5 px-4 sm:px-6 md:grid-cols-3">
      {
        principles.map((item, index) => {
          const key = principleKeys[index];

          return (
            <article class="border border-slate-200 bg-white p-7 dark:border-slate-800 dark:bg-slate-950">
              <Icon name={item.icon} class="h-9 w-9 text-blue-700 dark:text-blue-300" />
              <p
                class="mt-6 text-sm font-semibold uppercase tracking-wide text-slate-500 dark:text-slate-400"
                data-i18n-key={`data.principles.${key}.title`}
              >
                {t(`data.principles.${key}.title`)}
              </p>
              <h2
                class="mt-2 text-2xl font-bold text-slate-950 dark:text-white"
                data-i18n-key={`data.principles.${key}.label`}
              >
                {t(`data.principles.${key}.label`)}
              </h2>
              <p
                class="mt-4 leading-relaxed text-slate-600 dark:text-slate-300"
                data-i18n-key={`data.principles.${key}.description`}
              >
                {t(`data.principles.${key}.description`)}
              </p>
            </article>
          );
        })
      }
    </div>
  </section>

  <section class="not-prose bg-white py-16 dark:bg-slate-950 md:py-24">
    <div class="mx-auto grid max-w-7xl gap-12 px-4 sm:px-6 lg:grid-cols-[0.8fr_1.2fr]">
      <div>
        <p
          class="text-sm font-bold uppercase tracking-wide text-blue-700 dark:text-blue-300"
          data-i18n-key="pages.philosophy.guardrailsEyebrow"
        >
          {t('pages.philosophy.guardrailsEyebrow')}
        </p>
        <h2
          class="mt-3 text-3xl font-bold tracking-tight text-slate-950 dark:text-white md:text-5xl"
          data-i18n-key="pages.philosophy.guardrailsTitle"
        >
          {t('pages.philosophy.guardrailsTitle')}
        </h2>
      </div>
      <div class="space-y-3">
        {
          safeguards.map((item) => (
            <div class="flex gap-4 border border-slate-200 p-5 dark:border-slate-800">
              <Icon name="tabler:check" class="mt-1 h-5 w-5 shrink-0 text-blue-700 dark:text-blue-300" />
              <p
                class="leading-relaxed text-slate-600 dark:text-slate-300"
                data-i18n-key={`pages.philosophy.safeguards.${item}`}
              >
                {t(`pages.philosophy.safeguards.${item}`)}
              </p>
            </div>
          ))
        }
      </div>
    </div>
  </section>
</Layout>
