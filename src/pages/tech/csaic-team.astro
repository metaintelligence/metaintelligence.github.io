---
import { Icon } from 'astro-icon/components';

import Layout from '~/layouts/PageLayout.astro';
import { team } from '~/data/site';

const metadata = {
  title: 'CSAIC Team',
  description: 'MetaIntelligence CSAIC team profiles focused on public technical roles and expertise.',
};
---

<Layout metadata={metadata}>
  <section class="not-prose bg-white py-16 dark:bg-slate-950 md:py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6">
      <div class="max-w-4xl">
        <p class="text-sm font-bold uppercase tracking-wide text-blue-700 dark:text-blue-300">CSAIC Team</p>
        <h1 class="mt-4 text-4xl font-bold tracking-tight text-slate-950 dark:text-white md:text-6xl">
          Computational science, AI research, and product engineering in one team
        </h1>
        <p class="mt-6 text-lg leading-relaxed text-slate-600 dark:text-slate-300 md:text-xl">
          CSAIC stands for Computational Science & AI Center, the research and product team behind MetaIntelligence.
          Public profiles are limited to role, expertise, and relevant professional background.
        </p>
      </div>
    </div>
  </section>

  <section class="not-prose bg-slate-50 py-16 dark:bg-slate-900 md:py-24">
    <div class="mx-auto grid max-w-7xl gap-5 px-4 sm:px-6 lg:grid-cols-3">
      {
        team.map((member) => (
          <article class="flex min-h-[310px] flex-col border border-slate-200 bg-white p-7 dark:border-slate-800 dark:bg-slate-950">
            <div class="flex h-12 w-12 items-center justify-center bg-slate-100 text-blue-700 dark:bg-slate-900 dark:text-blue-300">
              <Icon name="tabler:user-square-rounded" class="h-7 w-7" />
            </div>
            <h2 class="mt-6 text-2xl font-bold text-slate-950 dark:text-white">{member.name}</h2>
            <p class="mt-1 text-sm font-semibold uppercase tracking-wide text-blue-700 dark:text-blue-300">
              {member.role}
            </p>
            <p class="mt-4 text-sm font-medium text-slate-500 dark:text-slate-400">{member.specialty}</p>
            <p class="mt-4 grow leading-relaxed text-slate-600 dark:text-slate-300">{member.summary}</p>
          </article>
        ))
      }
    </div>
  </section>

  <section class="not-prose bg-white py-16 dark:bg-slate-950 md:py-24">
    <div class="mx-auto grid max-w-7xl gap-8 px-4 sm:px-6 lg:grid-cols-[0.8fr_1.2fr]">
      <div>
        <p class="text-sm font-bold uppercase tracking-wide text-blue-700 dark:text-blue-300">Team System</p>
        <h2 class="mt-3 text-3xl font-bold tracking-tight text-slate-950 dark:text-white md:text-5xl">
          Small enough to stay accountable, broad enough to build full systems
        </h2>
      </div>
      <div class="grid gap-4 md:grid-cols-2">
        {
          [
            ['Research', 'First-principle modeling, R&D data analytics, algorithm design'],
            ['Product', 'MVI, MetaInsight, and DIANA product workflows and user experience'],
            ['Operations', 'Public R&D deliverables, data quality management, and pipeline reliability'],
            ['Verification', 'LLM evaluation, source-data comparison, and grounded reporting'],
          ].map(([title, description]) => (
            <div class="border border-slate-200 p-5 dark:border-slate-800">
              <h3 class="font-bold text-slate-950 dark:text-white">{title}</h3>
              <p class="mt-2 text-sm leading-relaxed text-slate-600 dark:text-slate-300">{description}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>
</Layout>
