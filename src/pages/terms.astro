---
import Layout from '~/layouts/PageLayout.astro';
import { company } from '~/data/site';
import { createTranslator } from '~/utils/i18n';

const t = createTranslator();

const metadata = {
  title: t('pages.terms.metaTitle'),
};
---

<Layout metadata={metadata}>
  <section class="not-prose bg-white py-16 dark:bg-slate-950 md:py-24">
    <div class="mx-auto max-w-4xl px-4 sm:px-6">
      <p
        class="text-sm font-bold uppercase tracking-wide text-blue-700 dark:text-blue-300"
        data-i18n-key="pages.terms.updated"
      >
        {t('pages.terms.updated')}
      </p>
      <h1
        class="mt-4 text-4xl font-bold tracking-tight text-slate-950 dark:text-white md:text-5xl"
        data-i18n-key="pages.terms.metaTitle"
      >
        {t('pages.terms.metaTitle')}
      </h1>
      <p class="mt-6 text-lg leading-relaxed text-slate-600 dark:text-slate-300" data-i18n-key="pages.terms.intro">
        {t('pages.terms.intro')}
      </p>

      <div class="mt-10 space-y-8 text-slate-600 dark:text-slate-300">
        <section>
          <h2 class="text-2xl font-bold text-slate-950 dark:text-white" data-i18n-key="pages.terms.contentTitle">
            {t('pages.terms.contentTitle')}
          </h2>
          <p class="mt-3 leading-relaxed" data-i18n-key="pages.terms.content">{t('pages.terms.content')}</p>
        </section>
        <section>
          <h2 class="text-2xl font-bold text-slate-950 dark:text-white" data-i18n-key="pages.terms.ipTitle">
            {t('pages.terms.ipTitle')}
          </h2>
          <p class="mt-3 leading-relaxed" data-i18n-key="pages.terms.ip">{t('pages.terms.ip')}</p>
        </section>
        <section>
          <h2 class="text-2xl font-bold text-slate-950 dark:text-white" data-i18n-key="pages.terms.linksTitle">
            {t('pages.terms.linksTitle')}
          </h2>
          <p class="mt-3 leading-relaxed" data-i18n-key="pages.terms.links">{t('pages.terms.links')}</p>
        </section>
        <section>
          <h2 class="text-2xl font-bold text-slate-950 dark:text-white" data-i18n-key="pages.terms.prohibitedTitle">
            {t('pages.terms.prohibitedTitle')}
          </h2>
          <p class="mt-3 leading-relaxed" data-i18n-key="pages.terms.prohibited">{t('pages.terms.prohibited')}</p>
        </section>
        <section>
          <h2 class="text-2xl font-bold text-slate-950 dark:text-white" data-i18n-key="pages.terms.contactTitle">
            {t('pages.terms.contactTitle')}
          </h2>
          <p class="mt-3 leading-relaxed" data-i18n-key="pages.terms.contact">{t('pages.terms.contact')}</p>
          <ul class="mt-3 space-y-1">
            <li>
              <span data-i18n-key="pages.contact.labels.email">{t('pages.contact.labels.email')}</span>:
              <a class="text-blue-700 hover:underline dark:text-blue-300" href={`mailto:${company.email}`}
                >{company.email}</a
              >
            </li>
            <li>
              <span data-i18n-key="pages.contact.labels.phone">{t('pages.contact.labels.phone')}</span>:
              <a class="text-blue-700 hover:underline dark:text-blue-300" href="tel:+82537194290">{company.phone}</a>
            </li>
          </ul>
        </section>
      </div>
    </div>
  </section>
</Layout>
